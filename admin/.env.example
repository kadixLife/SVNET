# SVNET Admin Panel v1.1.0-alpha.1
NODE_ENV=production

# Web ports are bound to 127.0.0.1 by docker-compose.
# Put Nginx in front of them for browser access.
FRONTEND_PORT=3000
BACKEND_PORT=3001
FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE=/api

# Admin auth.
# Generate a bcrypt hash and paste it here. Do not store plaintext passwords.
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=CHANGE_BCRYPT_HASH
JWT_SECRET=CHANGE_LONG_RANDOM_SECRET
AUTH_COOKIE_NAME=svnet_admin_session
COOKIE_SECURE=false

# PostgreSQL.
POSTGRES_USER=svnet_admin
POSTGRES_PASSWORD=CHANGE_POSTGRES_PASSWORD
POSTGRES_DB=svnet_admin
DATABASE_URL=postgres://svnet_admin:CHANGE_POSTGRES_PASSWORD@postgres:5432/svnet_admin

# SVNET host integration.
SVNET_CLI=/usr/local/bin/svnet
SVNET_BASE_DIR=/opt/svobodanet

# MikroTik read-only checks.
MIKROTIK_HOST=10.88.0.2
MIKROTIK_API_PORT=8728
