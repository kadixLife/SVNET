atomic_generate() {
  local target="$1"
  local generator="$2"
  local server_ip="$3"
  local tmp="${target}.tmp.$$"

  mkdir -p "$(dirname "$target")"

  if "$generator" "$server_ip" > "$tmp" && [[ -s "$tmp" ]]; then
    mv -f "$tmp" "$target"
    chmod 0644 "$target" 2>/dev/null || true
    ok "Generated: $target"
    return 0
  fi

  rm -f "$tmp"
  fail "Не удалось сгенерировать непустой файл: $target"
  return 1
}

verify_generated_rsc() {
  local files=(
    "$MIKROTIK/mikrotik-vpn-install.rsc"
    "$MIKROTIK/mikrotik-vpn-split-vpnfirst.rsc"
    "$MIKROTIK/mikrotik-vpn-fullvpn.rsc"
    "$MIKROTIK/mikrotik-vpn-direct.rsc"
    "$MIKROTIK/mikrotik-vpn-scripts.rsc"
    "$MIKROTIK/mikrotik-vpn-update-lists.rsc"
  )
  local f bad=0
  for f in "${files[@]}"; do
    if [[ -s "$f" ]]; then
      ok ".rsc не пустой: $f"
    else
      fail ".rsc отсутствует или пустой: $f"
      ((bad++))
    fi
  done
  return "$bad"
}

