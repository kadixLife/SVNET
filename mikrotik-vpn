    }
    :do {
        /interface ovpn-client import-ovpn-configuration ovpn-configuration=\$mvpnOvpnFile ovpn-user=ovpnuser skip-cert-import=no
    } on-error={
        :log warning "MikroTik_VPN: automatic OpenVPN import failed. Import mikrotik.ovpn manually, then run this script again."
    }
}

:if ([:len [/interface ovpn-client find name="$MIKROTIK_OVPN_IF"]] = 0) do={
    :error "MikroTik_VPN: OpenVPN interface $MIKROTIK_OVPN_IF is still missing"
}

/interface ovpn-client
set [find name="$MIKROTIK_OVPN_IF"] connect-to=$server_ip protocol=$OVPN_PROTO route-nopull=yes use-peer-dns=no disabled=no

RSC
}

