generate_mikrotik_configs() {
  require_root || return 1
  load_config
  ensure_base_dirs
  ensure_default_lists || return 1

  if [[ "$(detect_mode)" == "Safe Upgrade Mode" ]]; then
    create_backup "pre-mikrotik-generate" || return 1
  fi

  if [[ ! -s "$CLIENTS/mikrotik.ovpn" ]]; then
    warn "Не найден $CLIENTS/mikrotik.ovpn. Install script сможет обновить правила, но новый import OpenVPN может потребовать ручной файл."
  elif [[ ! -s "$MIKROTIK/mikrotik.ovpn" ]]; then
    cp -a "$CLIENTS/mikrotik.ovpn" "$MIKROTIK/mikrotik.ovpn"
    ok "Скопирован $MIKROTIK/mikrotik.ovpn"
  fi

  local server_ip
  server_ip="$(get_server_ip)"

  status_openvpn || true
  echo

  atomic_generate "$MIKROTIK/mikrotik-vpn-install.rsc" gen_install_rsc "$server_ip" || return 1
  atomic_generate "$MIKROTIK/mikrotik-vpn-split-vpnfirst.rsc" gen_split_vpnfirst_rsc "$server_ip" || return 1
  atomic_generate "$MIKROTIK/mikrotik-vpn-fullvpn.rsc" gen_fullvpn_rsc "$server_ip" || return 1
  atomic_generate "$MIKROTIK/mikrotik-vpn-direct.rsc" gen_direct_rsc "$server_ip" || return 1
  atomic_generate "$MIKROTIK/mikrotik-vpn-scripts.rsc" gen_scripts_rsc "$server_ip" || return 1
  atomic_generate "$MIKROTIK/mikrotik-vpn-update-lists.rsc" gen_update_lists_rsc "$server_ip" || return 1

  verify_generated_rsc || return 1
  show_mikrotik_install_command
}

check_mikrotik_connection() {
