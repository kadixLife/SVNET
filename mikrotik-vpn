CONF
  chmod 0600 "$CONFIG" 2>/dev/null || true
  ok "Конфиг сохранён: $CONFIG"
}

install_compat_alias() {
  cat > /usr/local/bin/svnet <<'ALIAS'
#!/usr/bin/env bash
exec /usr/local/bin/mikrotik-vpn "$@"
ALIAS
  chmod 0755 /usr/local/bin/svnet
}

supported_os() {
  [[ -r /etc/os-release ]] || return 1
  # shellcheck disable=SC1091
  . /etc/os-release
  [[ "${ID:-}" == "ubuntu" ]] || return 1
  [[ "${VERSION_ID:-}" == "22.04" || "${VERSION_ID:-}" == "24.04" ]]
}

prompt_install_config() {
  load_config
  SERVER_IP="${SERVER_IP:-$(get_server_ip)}"
  WAN_IF="${WAN_IF:-$(detect_wan_if)}"
  WAN_IF="${WAN_IF:-wan}"

  echo
  echo "Параметры установки:"
  echo "- Public IP: $SERVER_IP"
  echo "- WAN interface: $WAN_IF"
  echo "- OpenVPN: $OVPN_PROTO/$OVPN_PORT"
  echo "- VPN network: $VPN_NET"
  echo "- Server tunnel IP: $VPN_SERVER_IP"
  echo "- MikroTik tunnel IP: $MIKROTIK_VPN_IP"
  echo "- MikroTik LAN: $MIKROTIK_LAN"
  echo

  if confirm "Изменить параметры перед установкой?"; then
    SERVER_IP="$(prompt_value SERVER_IP "$SERVER_IP")"
    WAN_IF="$(prompt_value WAN_IF "$WAN_IF")"
    OVPN_PORT="$(prompt_value OVPN_PORT "$OVPN_PORT")"
    VPN_NET="$(prompt_value VPN_NET "$VPN_NET")"
    VPN_CIDR="$VPN_NET"
    VPN_SERVER_IP="$(prompt_value VPN_SERVER_IP "$VPN_SERVER_IP")"
    MIKROTIK_VPN_IP="$(prompt_value MIKROTIK_VPN_IP "$MIKROTIK_VPN_IP")"
    CLIENT_IP="$MIKROTIK_VPN_IP"
    MIKROTIK_LAN="$(prompt_value MIKROTIK_LAN "$MIKROTIK_LAN")"
    MIKROTIK_LAN_DNS="$(prompt_value MIKROTIK_LAN_DNS "$MIKROTIK_LAN_DNS")"
    MIKROTIK_WAN="$(prompt_value MIKROTIK_WAN "$MIKROTIK_WAN")"
    MIKROTIK_OVPN_IF="$(prompt_value MIKROTIK_OVPN_IF "$MIKROTIK_OVPN_IF")"
    HTTP_PORT="$(prompt_value HTTP_PORT "$HTTP_PORT")"
  fi

  write_config
}

install_server_packages() {
  if ! command_exists apt-get; then
    fail "apt-get не найден. Автоустановка поддерживает Ubuntu VPS."
    return 1
  fi

  apt-get update || return 1
  DEBIAN_FRONTEND=noninteractive apt-get install -y \
    git openvpn easy-rsa iptables-persistent curl wget python3 rsync ca-certificates \
    || return 1
}

cidr_network() {
  python3 - "$1" <<'PY'
import ipaddress, sys
print(ipaddress.ip_network(sys.argv[1], strict=False).network_address)
PY
}

cidr_netmask() {
  python3 - "$1" <<'PY'
import ipaddress, sys
print(ipaddress.ip_network(sys.argv[1], strict=False).netmask)
PY
}

write_openvpn_server_config() {
  local vpn_network vpn_netmask
  vpn_network="$(cidr_network "$VPN_NET")"
  vpn_netmask="$(cidr_netmask "$VPN_NET")"

  mkdir -p /etc/openvpn/server/ccd /var/log/openvpn
  cat > "$OVPN_SERVER_CONF" <<OVPN
port $OVPN_PORT
proto $OVPN_PROTO
dev $OVPN_IF
topology subnet

ca $EASYRSA_DIR/pki/ca.crt
cert $EASYRSA_DIR/pki/issued/server.crt
key $EASYRSA_DIR/pki/private/server.key
dh $EASYRSA_DIR/pki/dh.pem
crl-verify $EASYRSA_DIR/pki/crl.pem

server $vpn_network $vpn_netmask
ifconfig-pool-persist /var/log/openvpn/mikrotik-vpn-ipp.txt
client-config-dir /etc/openvpn/server/ccd
client-to-client
keepalive 10 120

cipher AES-128-GCM
auth SHA256
user nobody
group nogroup
persist-key
persist-tun
verb 3
status /var/log/openvpn/mikrotik-vpn-status.log
log-append /var/log/openvpn/mikrotik-vpn.log
explicit-exit-notify 1
OVPN

  printf 'ifconfig-push %s %s\n' "$MIKROTIK_VPN_IP" "$vpn_netmask" > "/etc/openvpn/server/ccd/$CLIENT_NAME"
}

setup_easyrsa_and_openvpn() {
  load_config
  mkdir -p "$EASYRSA_DIR"

  if [[ ! -x "$EASYRSA_DIR/easyrsa" ]]; then
    cp -a /usr/share/easy-rsa/* "$EASYRSA_DIR/"
  fi

  if [[ ! -d "$EASYRSA_DIR/pki" ]]; then
    (cd "$EASYRSA_DIR" && EASYRSA_BATCH=1 ./easyrsa init-pki) || return 1
    (cd "$EASYRSA_DIR" && EASYRSA_BATCH=1 EASYRSA_REQ_CN="MikroTik_VPN-CA" ./easyrsa build-ca nopass) || return 1
    (cd "$EASYRSA_DIR" && EASYRSA_BATCH=1 ./easyrsa gen-dh) || return 1
    (cd "$EASYRSA_DIR" && EASYRSA_BATCH=1 ./easyrsa build-server-full server nopass) || return 1
    (cd "$EASYRSA_DIR" && EASYRSA_BATCH=1 ./easyrsa build-client-full "$CLIENT_NAME" nopass) || return 1
    (cd "$EASYRSA_DIR" && EASYRSA_BATCH=1 ./easyrsa gen-crl) || return 1
  else
    warn "EasyRSA PKI уже существует, ключи и сертификаты не пересоздаются."
    if [[ ! -f "$EASYRSA_DIR/pki/issued/${CLIENT_NAME}.crt" ]]; then
      (cd "$EASYRSA_DIR" && EASYRSA_BATCH=1 ./easyrsa build-client-full "$CLIENT_NAME" nopass) || return 1
    fi
  fi

  write_openvpn_server_config || return 1
  systemctl enable "$OVPN_SERVICE" >/dev/null || return 1
  systemctl restart "$OVPN_SERVICE" || return 1
  ok "OpenVPN service запущен: $OVPN_SERVICE"
}

setup_firewall() {
  load_config
  sysctl -w net.ipv4.ip_forward=1 >/dev/null
  printf 'net.ipv4.ip_forward=1\n' > /etc/sysctl.d/99-mikrotik-vpn.conf

  iptables -C INPUT -i "$OVPN_IF" -j ACCEPT 2>/dev/null || iptables -I INPUT 1 -i "$OVPN_IF" -j ACCEPT
  iptables -C INPUT -p "$OVPN_PROTO" --dport "$OVPN_PORT" -j ACCEPT 2>/dev/null || iptables -I INPUT 1 -p "$OVPN_PROTO" --dport "$OVPN_PORT" -j ACCEPT
  iptables -C FORWARD -i "$OVPN_IF" -o "$WAN_IF" -j ACCEPT 2>/dev/null || iptables -I FORWARD 1 -i "$OVPN_IF" -o "$WAN_IF" -j ACCEPT
  iptables -C FORWARD -i "$WAN_IF" -o "$OVPN_IF" -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT 2>/dev/null \
    || iptables -I FORWARD 2 -i "$WAN_IF" -o "$OVPN_IF" -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT
  iptables -t nat -C POSTROUTING -s "$VPN_NET" -o "$WAN_IF" -j MASQUERADE 2>/dev/null \
    || iptables -t nat -A POSTROUTING -s "$VPN_NET" -o "$WAN_IF" -j MASQUERADE

  netfilter-persistent save >/dev/null 2>&1 || true
  ok "Firewall/NAT проверены и дополнены без очистки чужих правил."
}

generate_mikrotik_ovpn() {
  load_config
  mkdir -p "$CLIENTS" "$MIKROTIK"

  cat > "$CLIENTS/mikrotik.ovpn" <<OVPN
client
dev tun
proto $OVPN_PROTO
remote $(get_server_ip) $OVPN_PORT
nobind
persist-key
persist-tun
remote-cert-tls serve
cipher AES-128-GCM
auth SHA256
auth-nocache
verb 3
route-nopull
pull-filter ignore "redirect-gateway"
tun-mtu 1500
mssfix 1360

<ca>
$(cat "$EASYRSA_DIR/pki/ca.crt")
</ca>
<cert>
$(cat "$EASYRSA_DIR/pki/issued/${CLIENT_NAME}.crt")
</cert>
<key>
$(cat "$EASYRSA_DIR/pki/private/${CLIENT_NAME}.key")
</key>
OVPN
  cp -a "$CLIENTS/mikrotik.ovpn" "$MIKROTIK/mikrotik.ovpn"
  chmod 0600 "$CLIENTS/mikrotik.ovpn" 2>/dev/null || true
  chmod 0644 "$MIKROTIK/mikrotik.ovpn" 2>/dev/null || true
  ok "MikroTik .ovpn создан."
}

register_default_device() {
  mkdir -p "$DEVICES"
  cat > "$DEVICES/main.conf" <<CONF
name="main"
protocol="OpenVPN"
tunnel_ip="$MIKROTIK_VPN_IP"
client_name="$CLIENT_NAME"
created_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
last_generated_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
status="generated"
CONF
}

device_config_file() {
  local name="$1"
  printf '%s/%s.conf\n' "$DEVICES" "$name"
}

validate_device_name() {
  [[ "$1" =~ ^[A-Za-z0-9_-]{1,32}$ ]]
}

next_device_ip() {
  local used last_octet ip
  used="$(grep -h '^tunnel_ip=' "$DEVICES"/*.conf 2>/dev/null | cut -d= -f2 | tr -d '"' || true)"
  for last_octet in $(seq 2 254); do
    ip="10.88.0.${last_octet}"
    if ! printf '%s\n' "$used" | grep -Fxq "$ip"; then
      printf '%s\n' "$ip"
      return 0
    fi
  done
  return 1
}

list_devices() {
  load_config
  mkdir -p "$DEVICES"
  local file found=0
  for file in "$DEVICES"/*.conf; do
    [[ -f "$file" ]] || continue
    found=1
    # shellcheck disable=SC1090
    source "$file"
    echo "- ${name:-unknown}: ${protocol:-OpenVPN}, IP ${tunnel_ip:-unknown}, client ${client_name:-unknown}, status ${status:-unknown}"
  done
  [[ "$found" == "1" ]] || warn "Устройства пока не добавлены."
}

generate_device() {
  require_root || return 1
  load_config
  mkdir -p "$DEVICES"

  local name ip client file
  name="${1:-}"
  if [[ -z "$name" ]]; then
    read -r -p "Введите имя устройства, например home, office, test: " name || return 1
  fi
  validate_device_name "$name" || {
    fail "Имя устройства должно содержать только латиницу, цифры, _ или -."
    return 1
  }

  file="$(device_config_file "$name")"
  if [[ -f "$file" ]]; then
    fail "Устройство уже существует: $name"
    return 1
  fi

  ip="$(next_device_ip)" || {
    fail "Нет свободных IP в 10.88.0.0/24."
    return 1
  }
  client="mikrotik-${name}"

  if [[ -x "$EASYRSA_DIR/easyrsa" && ! -f "$EASYRSA_DIR/pki/issued/${client}.crt" ]]; then
    (cd "$EASYRSA_DIR" && EASYRSA_BATCH=1 ./easyrsa build-client-full "$client" nopass) || return 1
    printf 'ifconfig-push %s %s\n' "$ip" "$(cidr_netmask "$VPN_NET")" > "/etc/openvpn/server/ccd/$client"
  else
    warn "EasyRSA не найден или сертификат уже есть. Создана только запись устройства."
  fi

  cat > "$file" <<CONF
name="$name"
protocol="OpenVPN"
tunnel_ip="$ip"
client_name="$client"
created_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
last_generated_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
status="generated"
CONF
  ok "Устройство добавлено: $name ($ip)"
  generate_mikrotik_configs || true
  show_mikrotik_install_command
}

remove_device() {
  require_root || return 1
  load_config
  local name file
  name="${1:-}"
  if [[ -z "$name" ]]; then
    read -r -p "Введите имя устройства для удаления: " name || return 1
  fi
  validate_device_name "$name" || {
    fail "Некорректное имя устройства."
    return 1
  }
  file="$(device_config_file "$name")"
  [[ -f "$file" ]] || {
    fail "Устройство не найдено: $name"
    return 1
  }
  create_backup "pre-remove-device-${name}" || return 1
  rm -f "$file"
  ok "Устройство удалено из локального списка: $name"
  echo "На MikroTik повторно импортируйте актуальный mikrotik-vpn-install.rsc, чтобы пересобрать правила проекта."
}

