write_config() {
  ensure_base_dirs
  cat > "$CONFIG" <<CONF
MIKROTIK_VPN_VERSION="$VERSION"
BASE_DIR="$BASE_DIR"
CONFIG="$CONFIG"
LISTS="$LISTS"
OUTPUT="$OUTPUT"
CLIENTS="$CLIENTS"
MIKROTIK="$MIKROTIK"
BACKUPS="$BACKUPS"
DEVICES="$DEVICES"
REPO_DIR="$REPO_DIR"
MIKROTIK_VPN_GIT_URL="$MIKROTIK_VPN_GIT_URL"

SERVER_IP="$SERVER_IP"
WAN_IF="$WAN_IF"

OVPN_SERVICE="$OVPN_SERVICE"
OVPN_NAME="$OVPN_NAME"
OVPN_IF="$OVPN_IF"
OVPN_PROTO="$OVPN_PROTO"
OVPN_PORT="$OVPN_PORT"
VPN_NET="$VPN_NET"
VPN_CIDR="$VPN_CIDR"
