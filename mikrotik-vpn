install_connection() {
  require_root || return 1
  if [[ -f "${BASH_SOURCE[0]}" ]]; then
    install -m 0755 "${BASH_SOURCE[0]}" "$CLI" 2>/dev/null || true
    install_compat_alias 2>/dev/null || true
  fi

  supported_os || {
    fail "Поддерживаются Ubuntu 22.04 и 24.04."
    return 1
  }

  if [[ "$(detect_mode)" != "Fresh Install Mode" ]]; then
    warn "MikroTik VPN уже установлен или OpenVPN service найден."
    confirm "Пересоздать конфиги без удаления существующих ключей?" || return 0
    create_backup "pre-install-refresh" || return 1
  fi

  echo "Доступные протоколы:"
  echo
  echo "1) OpenVPN UDP - рекомендуется"
  echo "   Самый совместимый вариант для MikroTik RouterOS."
  echo
  echo "Скоро:"
  echo "2) WireGuard - позже"
  echo "3) AmneziaWG - позже"
  echo "4) Xray/VLESS - позже"
  echo
  read -r -p "Выберите протокол [1]: " protocol_choice || protocol_choice="1"
  if [[ -n "$protocol_choice" && "$protocol_choice" != "1" ]]; then
    fail "Сейчас доступен только OpenVPN UDP."
    return 1
  fi

  prompt_install_config || return 1
  install_server_packages || return 1
  ensure_default_lists || return 1
  setup_easyrsa_and_openvpn || return 1
  setup_firewall || return 1
  generate_mikrotik_ovpn || return 1
  register_default_device
  generate_mikrotik_configs || return 1
  create_backup "post-install" || true
  show_final_install_message
}

full_remove_connection() {
  require_root || return 1
  load_config
  warn "Полное удаление остановит OpenVPN и удалит сгенерированные конфиги MikroTik VPN."
  warn "Git repo не удаляется этой командой."
  confirm_word "Для продолжения нужно явное подтверждение." "DELETE_MIKROTIK_VPN" || return 0
  create_backup "pre-full-remove" || return 1

  systemctl disable --now "$OVPN_SERVICE" >/dev/null 2>&1 || true
  systemctl disable --now "$HTTP_SERVICE" >/dev/null 2>&1 || true
  rm -f "$OVPN_SERVER_CONF" "$HTTP_SERVICE_FILE"
  rm -rf "$OUTPUT" "$DEVICES"
  systemctl daemon-reload >/dev/null 2>&1 || true
  ok "OpenVPN service и generated configs удалены. Списки и Git repo оставлены."
}

safe_remove_stage() {
  local stage="$1"
  case "$stage" in
    "$BACKUPS"/.staging-*) rm -rf -- "$stage" ;;
    *) warn "Временная директория backup не удалена: $stage" ;;
  esac
}

copy_path_to_stage() {
  local src="$1"
  local dst="$2"
  if [[ -e "$src" ]]; then
    mkdir -p "$(dirname "$dst")"
    cp -a "$src" "$dst"
  fi
}

cleanup_regular_backups() {
  local backups
  mapfile -t backups < <(find "$BACKUPS" -maxdepth 1 -type f -name 'mikrotik-vpn-backup-manual-*.tar.gz' 2>/dev/null | sort)
  local count="${#backups[@]}"
  local remove_count=$((count - 3))

  if (( remove_count <= 0 )); then
    return 0
  fi

  local i
  for ((i = 0; i < remove_count; i++)); do
    rm -f -- "${backups[$i]}"
  done
}

create_backup() {
  local kind="${1:-manual}"
  require_root || return 1
  load_config
  ensure_base_dirs

  local ts archive stage
  ts="$(date +%Y-%m-%d_%H-%M-%S)"
  archive="$BACKUPS/mikrotik-vpn-backup-${kind}-${ts}.tar.gz"
  stage="$BACKUPS/.staging-${kind}-${ts}-$$"

  mkdir -p "$stage"

  copy_path_to_stage "$BASE_DIR/config" "$stage/opt/mikrotik-vpn/config"
  copy_path_to_stage "$BASE_DIR/lists" "$stage/opt/mikrotik-vpn/lists"
  copy_path_to_stage "$BASE_DIR/devices" "$stage/opt/mikrotik-vpn/devices"
  copy_path_to_stage "$BASE_DIR/output" "$stage/opt/mikrotik-vpn/output"
  copy_path_to_stage "$OVPN_SERVER_CONF" "$stage/etc/openvpn/server/mikrotik-vpn.conf"
  copy_path_to_stage "$HTTP_SERVICE_FILE" "$stage/etc/systemd/system/mikrotik-vpn-http.service"
  copy_path_to_stage "$CLI" "$stage/usr/local/bin/mikrotik-vpn"

  if command_exists iptables-save; then
    iptables-save > "$stage/iptables-save.rules" 2>/dev/null || true
  fi

  if tar -czf "$archive" -C "$stage" .; then
    safe_remove_stage "$stage"
    [[ "$kind" == "manual" ]] && cleanup_regular_backups
    ok "Backup создан: $archive"
    return 0
  fi

  safe_remove_stage "$stage"
  fail "Backup создать не удалось."
  return 1
}

show_backups() {
  require_root || return 1
  ensure_base_dirs

  local backups
  mapfile -t backups < <(find "$BACKUPS" -maxdepth 1 -type f -name 'mikrotik-vpn-backup-*.tar.gz' 2>/dev/null | sort -r)

  if (( ${#backups[@]} == 0 )); then
    warn "Backups не найдены."
    return 0
  fi

  local i prefix
  for ((i = 0; i < ${#backups[@]}; i++)); do
    if (( i == 0 )); then
      prefix="${GREEN}"
    else
      prefix=""
    fi
    printf '%s%2d) %s%s\n' "$prefix" "$((i + 1))" "${backups[$i]}" "$RESET"
  done
}

restore_file_if_present() {
  local src="$1"
  local dst="$2"
  if [[ -e "$src" ]]; then
    mkdir -p "$(dirname "$dst")"
    cp -a "$src" "$dst"
  fi
}

restore_dir_if_present() {
  local src="$1"
  local dst="$2"
  if [[ -d "$src" ]]; then
    mkdir -p "$dst"
    cp -a "$src/." "$dst/"
  fi
}

restore_backup() {
  require_root || return 1
  ensure_base_dirs

  local backups
  mapfile -t backups < <(find "$BACKUPS" -maxdepth 1 -type f -name 'mikrotik-vpn-backup-*.tar.gz' 2>/dev/null | sort -r)
  if (( ${#backups[@]} == 0 )); then
    warn "Backups не найдены."
    return 0
  fi

  show_backups
  echo

  local choice archive stage
  read -r -p "Введите номер backup для восстановления: " choice || return 1
  if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#backups[@]} )); then
    fail "Неверный номер backup."
    return 1
  fi

  archive="${backups[$((choice - 1))]}"

  warn "Restore может перезаписать config/lists/output/OpenVPN/systemd/CLI."
  confirm_word "Перед restore будет создан pre-restore backup." "RESTORE" || {
    info "Restore отменён."
    return 0
  }

  create_backup "pre-restore" || return 1

  stage="$BACKUPS/.staging-restore-$(date +%Y-%m-%d_%H-%M-%S)-$$"
  mkdir -p "$stage"

  if ! tar -xzf "$archive" -C "$stage"; then
    safe_remove_stage "$stage"
    fail "Не удалось распаковать backup."
    return 1
  fi

  restore_dir_if_present "$stage/opt/mikrotik-vpn/config" "$BASE_DIR/config"
  restore_dir_if_present "$stage/opt/mikrotik-vpn/lists" "$BASE_DIR/lists"
  restore_dir_if_present "$stage/opt/mikrotik-vpn/output" "$BASE_DIR/output"
  restore_file_if_present "$stage/etc/openvpn/server/mikrotik-vpn.conf" "$OVPN_SERVER_CONF"
  restore_file_if_present "$stage/etc/systemd/system/mikrotik-vpn-http.service" "$HTTP_SERVICE_FILE"
  restore_file_if_present "$stage/usr/local/bin/mikrotik-vpn" "$CLI"

  if [[ -f "$stage/iptables-save.rules" ]]; then
    if confirm "Восстановить iptables из backup сейчас?"; then
      if command_exists iptables-restore; then
        iptables-restore < "$stage/iptables-save.rules" && ok "iptables восстановлены."
      else
        warn "iptables-restore не найден."
      fi
    else
      info "iptables сохранены в backup, но не применялись."
    fi
  fi

  safe_remove_stage "$stage"

  command_exists systemctl && systemctl daemon-reload >/dev/null 2>&1 || true
  ok "Restore завершён."
  status_openvpn
}

clean_old_backups() {
  require_root || return 1
  ensure_base_dirs
  cleanup_regular_backups
  ok "Старые обычные backups очищены. pre-* backups не удалялись."
}

check_http_url() {
  local url="$1"
  local code
  if ! command_exists curl; then
    warn "curl не найден: $url не проверен."
    return 1
  fi
  code="$(curl -fsS -o /dev/null -w '%{http_code}' -I "$url" 2>/dev/null || true)"
  [[ "$code" == "200" ]]
}

http_status_code() {
  local url="$1"
  local code
  if ! command_exists curl; then
    printf '%s\n' "curl-missing"
    return 0
  fi
  code="$(curl -sS -o /dev/null -w '%{http_code}' -I --max-time 5 "$url" 2>/dev/null || true)"
  printf '%s\n' "${code:-000}"
}

http_publish_urls() {
  printf '%s\n' \
    "/clients/mikrotik.ovpn" \
    "/mikrotik/mikrotik-vpn-install.rsc" \
    "/mikrotik/mikrotik-vpn-split-vpnfirst.rsc" \
    "/mikrotik/mikrotik-vpn-update-lists.rsc"
}

http_port_ss_lines() {
  command_exists ss || return 0
  ss -H -ltnp 2>/dev/null | grep -E "(:|\])${HTTP_PORT}\b" || true
}

http_port_wildcard_listener_lines() {
  http_port_ss_lines | grep -E "(^|[[:space:]])(0\.0\.0\.0:${HTTP_PORT}|\*:${HTTP_PORT}|\[::\]:${HTTP_PORT}|:::${HTTP_PORT})([[:space:]]|$)" || true
}

http_port_public_listener_lines() {
  local server_ip lines
  server_ip="$(get_server_ip)"
  lines="$(http_port_ss_lines)"
  {
    http_port_wildcard_listener_lines
    if [[ -n "$server_ip" && "$server_ip" != "SERVER_IP" && "$server_ip" != "$VPN_SERVER_IP" ]]; then
      printf '%s\n' "$lines" | grep -F "${server_ip}:${HTTP_PORT}" || true
    fi
  } | sort -u
}

http_port_pids() {
  http_port_ss_lines | grep -oE 'pid=[0-9]+' 2>/dev/null | cut -d= -f2 | sort -u
}

http_port_is_listening() {
  [[ -n "$(http_port_ss_lines)" ]]
}

pid_systemd_unit() {
  local pid="$1" unit

  if [[ -r "/proc/$pid/cgroup" ]]; then
    unit="$(grep -oE '[A-Za-z0-9_.@-]+\.service' "/proc/$pid/cgroup" 2>/dev/null | tail -n1 || true)"
    if [[ -n "$unit" ]]; then
      printf '%s\n' "$unit"
      return 0
    fi
  fi

  if command_exists systemctl; then
    unit="$(systemctl status "$pid" --no-pager 2>/dev/null | grep -m1 -oE '[A-Za-z0-9_.@-]+\.service' || true)"
    if [[ -n "$unit" ]]; then
      printf '%s\n' "$unit"
      return 0
    fi
  fi

  return 1
}

http_public_ip_code() {
  local server_ip code
  server_ip="$(get_server_ip)"
  if [[ -z "$server_ip" || "$server_ip" == "SERVER_IP" || "$server_ip" == "$VPN_SERVER_IP" ]]; then
    printf '%s\n' "skipped"
    return 0
  fi

  if ! command_exists curl; then
    printf '%s\n' "curl-missing"
    return 0
  fi

  code="$(curl -sS -o /dev/null -w '%{http_code}' -I --connect-timeout 3 --max-time 5 "http://${server_ip}:${HTTP_PORT}" 2>/dev/null || true)"
  printf '%s\n' "${code:-000}"
}

print_http_listener_status() {
  local service_active="${1:-unknown}"
  echo "HTTP port $HTTP_PORT listener"

  if ! command_exists ss; then
    warn "ss не найден: порт $HTTP_PORT не проверен."
    echo
    return 0
  fi

  local lines pids pid cwd unit
  lines="$(http_port_ss_lines)"
  if [[ -z "$lines" ]]; then
    if [[ "$service_active" == "yes" ]]; then
      fail "$HTTP_SERVICE active, but port $HTTP_PORT is not listening"
    else
      ok "port $HTTP_PORT: not listening"
    fi
    echo
    return 0
  fi

  ok "port $HTTP_PORT: listening"
  echo "$lines"
  echo "Served directory: $OUTPUT"
  mapfile -t pids < <(printf '%s\n' "$lines" | grep -oE 'pid=[0-9]+' 2>/dev/null | cut -d= -f2 | sort -u)

  if (( ${#pids[@]} == 0 )); then
    warn "PID процесса на $HTTP_PORT не определён."
    echo
    return 0
  fi

  for pid in "${pids[@]}"; do
    cwd="$(readlink -f "/proc/$pid/cwd" 2>/dev/null || true)"
    unit="$(pid_systemd_unit "$pid" 2>/dev/null || true)"
    echo "PID: $pid"
    if [[ -n "$unit" ]]; then
      echo "Systemd unit: $unit"
    else
      echo "Systemd unit: unknown"
    fi
    if [[ -n "$cwd" ]]; then
      echo "CWD: $cwd"
    else
      echo "CWD: недоступно"
    fi
  done
  echo
}

kill_http_port_listeners() {
  local pids pid
  mapfile -t pids < <(http_port_pids)
  if (( ${#pids[@]} == 0 )); then
    return 0
  fi

  for pid in "${pids[@]}"; do
    warn "Останавливаю процесс на порту $HTTP_PORT: PID $pid"
    kill "$pid" 2>/dev/null || true
  done

  sleep 1

  for pid in "${pids[@]}"; do
    if kill -0 "$pid" 2>/dev/null; then
      warn "PID $pid ещё жив, выполняю kill -9."
      kill -9 "$pid" 2>/dev/null || true
    fi
  done
}

known_legacy_service_candidates() {
  {
    printf '%s\n' "$LEGACY_KADI_HTTP_SERVICE"
    if command_exists systemctl; then
      systemctl list-unit-files --no-legend 'kadi*.service' 'kadi-*.service' 2>/dev/null | awk '{print $1}'
      systemctl list-units --all --no-legend 'kadi*.service' 'kadi-*.service' 2>/dev/null | awk '{print $1}'
    fi
  } | sort -u
}

systemd_unit_known() {
  local unit="$1"
  command_exists systemctl || return 1
  systemctl list-unit-files --no-legend "$unit" 2>/dev/null | awk '{print $1}' | grep -Fxq "$unit" && return 0
  systemctl list-units --all --no-legend "$unit" 2>/dev/null | awk '{print $1}' | grep -Fxq "$unit"
}

is_known_legacy_http_unit() {
  local unit="$1"
  [[ "$unit" == "$LEGACY_KADI_HTTP_SERVICE" ]]
}

disable_legacy_service_unit() {
  local unit="$1"
  command_exists systemctl || {
    warn "systemctl не найден, не могу отключить $unit."
    return 1
  }

  warn "Найден старый KADI service: $unit"
  confirm "Отключить старый KADI HTTP service $unit?" || return 1

  systemctl stop "$unit" >/dev/null 2>&1 || true
  systemctl disable "$unit" >/dev/null 2>&1 || true
  systemctl mask "$unit" >/dev/null 2>&1 || true
  systemctl daemon-reload >/dev/null 2>&1 || true
  ok "Legacy service disabled and masked: $unit"
}

cleanup_http_port_legacy_units() {
  local pids pid unit changed=0 declined=0
  mapfile -t pids < <(http_port_pids)

  for pid in "${pids[@]}"; do
    unit="$(pid_systemd_unit "$pid" 2>/dev/null || true)"
    [[ -n "$unit" ]] || continue
    if is_known_legacy_http_unit "$unit"; then
      if disable_legacy_service_unit "$unit"; then
        changed=1
      else
        declined=1
      fi
    fi
  done

  if [[ "$changed" == "1" ]]; then
    sleep 1
  fi

  [[ "$declined" == "0" ]]
}

verify_http_publish_public_closed() {
  local code public_lines problems=0

  if http_port_is_listening; then
    warn "ss показывает listener на $HTTP_PORT:"
    http_port_ss_lines
  else
    ok "ss: port $HTTP_PORT not listening"
  fi

  public_lines="$(http_port_public_listener_lines)"
  if [[ -n "$public_lines" ]]; then
    fail "HTTP publish ${HTTP_PORT}: public/wildcard listener найден"
    printf '%s\n' "$public_lines"
    ((problems++))
  else
    ok "HTTP publish ${HTTP_PORT}: no public/wildcard listener"
  fi

  code="$(http_public_ip_code)"
  case "$code" in
    000) ok "curl public IP:${HTTP_PORT}: refused/timeout" ;;
    skipped) warn "curl public IP:${HTTP_PORT}: skipped, public IP не определён" ;;
    curl-missing) warn "curl public IP:${HTTP_PORT}: curl не найден" ;;
    *) fail "curl public IP:${HTTP_PORT}: HTTP $code"; ((problems++)) ;;
  esac

  return "$problems"
}

cleanup_legacy_services() {
  require_root || return 1
  load_config

  local services unit found=0
  echo "Cleanup legacy KADI services"
  echo
  mapfile -t services < <(known_legacy_service_candidates)

  for unit in "${services[@]}"; do
    [[ -n "$unit" ]] || continue
    systemd_unit_known "$unit" || continue
    found=1
    disable_legacy_service_unit "$unit" || true
  done

  if [[ "$found" == "0" ]]; then
    ok "Known legacy KADI services не найдены."
  fi

  echo
  verify_http_publish_public_closed || return 1
}

write_http_publish_service() {
  load_config
  mkdir -p "$(dirname "$HTTP_SERVICE_FILE")"
  cat > "$HTTP_SERVICE_FILE" <<HTTP
[Unit]
Description=MikroTik VPN temporary config HTTP serve
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 -m http.server $HTTP_PORT --bind 0.0.0.0 --directory $OUTPUT
Restart=no

[Install]
WantedBy=multi-user.target
HTTP
}

verify_http_publish_urls() {
  load_config
  local mode="${1:-verbose}"
  local path code problems=0
  for path in $(http_publish_urls); do
    code="$(http_status_code "http://127.0.0.1:${HTTP_PORT}${path}")"
    if [[ "$code" == "200" ]]; then
      if [[ "$mode" != "quiet" ]]; then
        ok "HTTP $path: 200 OK"
      fi
    else
      if [[ "$mode" != "quiet" ]]; then
        warn "HTTP $path: $code"
      fi
      ((problems++))
    fi
  done
  return "$problems"
}

wait_for_http_publish_urls() {
  load_config
  local attempt
  info "Ждём запуск HTTP publish..."
  for attempt in {1..10}; do
    info "Проверка URL, попытка $attempt/10..."
    if verify_http_publish_urls quiet; then
      return 0
    fi
    sleep 1
  done

  fail "HTTP publish не вернул 200 OK для всех обязательных URL за 10 попыток."
  verify_http_publish_urls || true
  return 1
}

status_openvpn() {
  load_config
  local problems=0
  local server_ip
  server_ip="$(get_server_ip)"

  echo "Статус OpenVPN и публикации"
  echo

  if command_exists systemctl && systemctl is-active --quiet "$OVPN_SERVICE"; then
    ok "OpenVPN service: active"
  else
    fail "OpenVPN service: не active"
    ((problems++))
  fi

  if command_exists ip && ip -4 -o addr show dev "$OVPN_IF" >/dev/null 2>&1; then
    if ip -4 -o addr show dev "$OVPN_IF" 2>/dev/null | grep -q " ${VPN_SERVER_IP}/"; then
      ok "$OVPN_IF: $VPN_SERVER_IP"
    else
      warn "$OVPN_IF найден, но IP $VPN_SERVER_IP не подтверждён"
      ip -4 -o addr show dev "$OVPN_IF" 2>/dev/null || true
    fi
  else
    fail "$OVPN_IF: интерфейс не найден"
    ((problems++))
  fi

  if command_exists ss && ss -lunp 2>/dev/null | grep -Eq ":${OVPN_PORT}\b.*openvpn|:${OVPN_PORT}\b"; then
    ok "UDP port $OVPN_PORT: listening"
  else
    fail "UDP port $OVPN_PORT: не найден слушающий socket"
    ((problems++))
  fi

  if command_exists sysctl && [[ "$(sysctl -n net.ipv4.ip_forward 2>/dev/null || true)" == "1" ]]; then
    ok "net.ipv4.ip_forward=1"
  else
    warn "net.ipv4.ip_forward не равен 1 или sysctl недоступен"
  fi

  if command_exists iptables; then
    iptables -C INPUT -i "$OVPN_IF" -j ACCEPT 2>/dev/null && ok "iptables INPUT $OVPN_IF: есть" || warn "iptables INPUT $OVPN_IF: не найдено"
    iptables -C INPUT -p udp --dport "$OVPN_PORT" -j ACCEPT 2>/dev/null && ok "iptables INPUT udp/$OVPN_PORT: есть" || warn "iptables INPUT udp/$OVPN_PORT: не найдено"
    iptables -C FORWARD -i "$OVPN_IF" -o "$WAN_IF" -j ACCEPT 2>/dev/null && ok "iptables FORWARD $OVPN_IF -> $WAN_IF: есть" || warn "iptables FORWARD $OVPN_IF -> $WAN_IF: не найдено"
    iptables -C FORWARD -i "$WAN_IF" -o "$OVPN_IF" -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT 2>/dev/null \
      && ok "iptables FORWARD $WAN_IF -> $OVPN_IF RELATED,ESTABLISHED: есть" \
      || warn "iptables FORWARD $WAN_IF -> $OVPN_IF RELATED,ESTABLISHED: не найдено"
    iptables -t nat -C POSTROUTING -s "$VPN_CIDR" -o "$WAN_IF" -j MASQUERADE 2>/dev/null \
      && ok "NAT $VPN_CIDR -> $WAN_IF: есть" \
      || warn "NAT $VPN_CIDR -> $WAN_IF: не найдено"
  else
    warn "iptables не найден."
  fi

  if command_exists systemctl && systemctl is-active --quiet "$HTTP_SERVICE"; then
    ok "HTTP publish service: active"
    if check_http_url "http://127.0.0.1:${HTTP_PORT}/clients/mikrotik.ovpn"; then
      ok "HTTP clients/mikrotik.ovpn: 200 OK"
    else
      warn "HTTP clients/mikrotik.ovpn: нет 200 OK"
    fi

    if check_http_url "http://127.0.0.1:${HTTP_PORT}/mikrotik/mikrotik-vpn-split-vpnfirst.rsc"; then
      ok "HTTP split-vpnfirst.rsc: 200 OK"
    else
      warn "HTTP split-vpnfirst.rsc: нет 200 OK"
    fi
  else
    ok "HTTP publish: offline secure mode"
  fi

  local required=(
    "$CLIENTS/mikrotik.ovpn"
    "$MIKROTIK/mikrotik-vpn-split-vpnfirst.rsc"
    "$MIKROTIK/mikrotik-vpn-fullvpn.rsc"
    "$MIKROTIK/mikrotik-vpn-direct.rsc"
    "$MIKROTIK/mikrotik-vpn-scripts.rsc"
    "$MIKROTIK/mikrotik-vpn-update-lists.rsc"
  )
  local f
  for f in "${required[@]}"; do
    if [[ -s "$f" ]]; then
      ok "Output file: $f"
    else
      warn "Output file отсутствует или пустой: $f"
    fi
  done

  echo
  info "Публичная команда для MikroTik использует: http://$server_ip:$HTTP_PORT"
  return "$problems"
}

publish_on() {
  require_root || return 1
  load_config

  if ! command_exists systemctl; then
    fail "systemctl не найден."
    return 1
  fi

  systemctl stop "$HTTP_SERVICE" >/dev/null 2>&1 || true
  kill_http_port_listeners
  write_http_publish_service
  systemctl daemon-reload
  systemctl disable "$HTTP_SERVICE" >/dev/null 2>&1 || true
  if ! systemctl start "$HTTP_SERVICE"; then
    fail "Не удалось запустить $HTTP_SERVICE."
    return 1
  fi
  ok "HTTP publish включён временно."
  wait_for_http_publish_urls || return 1
  publish_status strict
}

publish_off() {
  require_root || return 1
  load_config

  if ! command_exists systemctl; then
    fail "systemctl не найден."
    return 1
  fi

  systemctl stop "$HTTP_SERVICE" >/dev/null 2>&1 || true
  systemctl disable "$HTTP_SERVICE" >/dev/null 2>&1 || true
  if http_port_is_listening; then
    cleanup_http_port_legacy_units || true
  fi
  kill_http_port_listeners
  if http_port_is_listening; then
    fail "Порт $HTTP_PORT всё ещё слушается."
    print_http_listener_status no
    return 1
  fi
  ok "HTTP publish отключён. OpenVPN не тронут."
  verify_http_publish_public_closed || true
  publish_status
}

publish_status() {
  load_config
  local strict="${1:-}"
  local server_ip active listening curl_result
  server_ip="$(get_server_ip)"
  active="no"
  listening="no"
  curl_result=0

  echo "HTTP publish status"
  echo

  if command_exists systemctl && systemctl is-active --quiet "$HTTP_SERVICE"; then
    active="yes"
    ok "$HTTP_SERVICE: active"
  fi

  if http_port_is_listening; then
    listening="yes"
  fi

  if [[ "$active" == "no" && "$listening" == "no" ]]; then
    ok "HTTP publish: offline secure mode"
  elif [[ "$active" == "no" ]]; then
    warn "$HTTP_SERVICE: inactive"
  fi

  if [[ "$active" == "no" && "$listening" == "yes" ]]; then
    warn "Найден посторонний HTTP process на $HTTP_PORT"
  fi
  print_http_listener_status "$active"

  echo
  echo "URL публикации:"
  echo "URL доступны только когда $HTTP_SERVICE active."
  echo "http://$server_ip:$HTTP_PORT/clients/mikrotik.ovpn"
  echo "http://$server_ip:$HTTP_PORT/mikrotik/mikrotik-vpn-install.rsc"
  echo "http://$server_ip:$HTTP_PORT/mikrotik/mikrotik-vpn-split-vpnfirst.rsc"
  echo

  if [[ "$active" == "no" && "$listening" == "no" ]]; then
    ok "URL конфигов недоступны, публикация отключена"
  else
    verify_http_publish_urls || curl_result=$?
  fi

  if [[ "$active" != "yes" && "$listening" == "yes" ]]; then
    info "Публикация конфигов отключена. Для установки MikroTik включите: sudo mikrotik-vpn --publish-on"
  fi

  [[ "$strict" == "strict" ]] && return "$curl_result"
  return 0
}

restart_openvpn() {
  require_root || return 1
  load_config

  warn "Будет создан backup и перезапущен $OVPN_SERVICE."
  confirm "Продолжить?" || {
    info "Перезапуск отменён."
    return 0
  }

  if [[ "$(detect_mode)" == "Safe Upgrade Mode" ]]; then
    create_backup "pre-openvpn-restart" || return 1
  fi

  if systemctl restart "$OVPN_SERVICE"; then
    sleep 2
    status_openvpn
  else
    fail "OpenVPN не перезапустился. Последние записи журнала:"
    journalctl -u "$OVPN_SERVICE" -n 80 --no-pager || true
    return 1
  fi
}

ensure_http_publish_service() {
  require_root || return 1
  load_config

  local desired_exec="/usr/bin/python3 -m http.server $HTTP_PORT --bind 0.0.0.0 --directory $OUTPUT"

  if [[ -f "$HTTP_SERVICE_FILE" ]] && grep -Fq -- "$desired_exec" "$HTTP_SERVICE_FILE" && grep -Fq "Restart=no" "$HTTP_SERVICE_FILE"; then
    ok "HTTP publish service уже использует --directory $OUTPUT"
    return 0
  fi

  warn "HTTP publish service отличается от безопасного шаблона, перезаписываю unit."
  write_http_publish_service
  systemctl daemon-reload
  ok "HTTP publish service обновлён."
}

clean_file() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  sed 's/\r$//' "$file" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | grep -vE '^($|#)' | sort -u
}

validate_domain() {
  local value="$1"
  [[ "$value" =~ ^([A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?\.)+[A-Za-z]{2,}$ ]]
}

validate_ip_or_cidr() {
  local value="$1"
  python3 - "$value" <<'PY' >/dev/null 2>&1
import ipaddress
import sys
ipaddress.ip_network(sys.argv[1], strict=False)
PY
}

normalize_value() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  value="${value#http://}"
  value="${value#https://}"
  if [[ "$value" == *"/"* && ! "$value" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/[0-9]+$ ]]; then
    value="${value%%/*}"
  fi
  value="${value%.}"
  value="${value,,}"
  printf '%s\n' "$value"
}

add_unique_line() {
  local file="$1"
  local value="$2"
  mkdir -p "$(dirname "$file")"
  touch "$file"
  if grep -qxF "$value" "$file"; then
    warn "Уже есть: $value"
    return 0
  fi
  printf '%s\n' "$value" >> "$file"
  sort -u "$file" -o "$file"
  ok "Добавлено: $value"
}

remove_line() {
  local file="$1"
  local value="$2"
  if [[ ! -f "$file" ]]; then
    warn "Список пока пуст."
    return 0
  fi
  if ! grep -qxF "$value" "$file"; then
    warn "Запись не найдена: $value"
    return 0
  fi
  grep -vxF "$value" "$file" > "${file}.tmp.$$"
  mv -f "${file}.tmp.$$" "$file"
  ok "Удалено: $value"
}

dedupe_list() {
  local file="$1"
  [[ -f "$file" ]] || : > "$file"
  clean_file "$file" > "${file}.tmp.$$"
  mv -f "${file}.tmp.$$" "$file"
  ok "Дубли очищены."
}

validate_list_file() {
  local file="$1"
  local type="$2"
  local invalid=0
  local duplicates=0
  local line

  if [[ ! -f "$file" ]]; then
    warn "Список не найден: $file"
    return 0
  fi

  while IFS= read -r line; do
    line="$(normalize_value "$line")"
    [[ -z "$line" || "$line" =~ ^# ]] && continue
    if [[ "$type" == "domain" ]]; then
      validate_domain "$line" || {
        fail "Неверный домен: $line"
        ((invalid++))
      }
    else
      validate_ip_or_cidr "$line" || {
        fail "Неверный IP/подсеть: $line"
        ((invalid++))
      }
    fi
  done < "$file"

  duplicates="$(sort "$file" 2>/dev/null | uniq -d | grep -vcE '^($|#)' || true)"
  if (( duplicates > 0 )); then
    warn "Найдены дубли: $duplicates"
  fi

  if (( invalid == 0 && duplicates == 0 )); then
    ok "Ошибки не найдены."
  else
    warn "Проверьте список перед генерацией MikroTik правил."
  fi

  return 0
}

list_file_by_key() {
