  echo

  echo "### Disk"
  df -h / "$BASE_DIR" 2>/dev/null || df -h /
  echo

  echo "### Installed packages / versions"
  command_exists openvpn && openvpn --version | head -n 3 || warn "openvpn не найден"
  [[ -x "$EASYRSA_DIR/easyrsa" ]] && "$EASYRSA_DIR/easyrsa" --version 2>/dev/null | head -n 3 || warn "easy-rsa не найден в $EASYRSA_DIR"
  command_exists iptables && iptables --version || warn "iptables не найден"
  command_exists netfilter-persistent && netfilter-persistent --help 2>&1 | head -n 2 || warn "netfilter-persistent не найден"
  command_exists curl && curl --version | head -n 1 || warn "curl не найден"
  command_exists wget && wget --version | head -n 1 || warn "wget не найден"
  echo

  echo "### systemd services"
  command_exists systemctl && systemctl --no-pager --full status "$OVPN_SERVICE" "$HTTP_SERVICE" | sed -n '1,80p' || true
  echo

  echo "### ports"
  command_exists ss && ss -lunp | grep -E ":${OVPN_PORT}\b|openvpn" || true
  command_exists ss && ss -ltnp | grep -E ":${HTTP_PORT}\b|python3" || true
  echo

  echo "### HTTP publish diagnostics"
  publish_status
  echo

  echo "### HTTP publish files"
  find "$OUTPUT" -maxdepth 3 -type f -printf '%s %p\n' 2>/dev/null | sort -n || true
  echo

  echo "### /opt/mikrotik-vpn structure"
  find "$BASE_DIR" -maxdepth 3 -printf '%M %s %p\n' 2>/dev/null | sort || true
  echo

  doctor_git_repo
}

resolve_update_repo() {
  load_config
  local script_dir git_root
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

  if [[ -d "$REPO_DIR" && ! -d "$REPO_DIR/.git" ]]; then
    warn "Repo folder exists, but it is not a Git repository."
    echo "Repair: sudo mikrotik-vpn --repair-git-repo"
    return 1
  fi

  if [[ -d "$REPO_DIR/.git" ]]; then
    printf '%s\n' "$REPO_DIR"
    return 0
  fi

  if [[ -d "$script_dir/.git" ]]; then
    printf '%s\n' "$script_dir"
    return 0
  fi

  git_root="$(git -C "$script_dir" rev-parse --show-toplevel 2>/dev/null || true)"
  if [[ -n "$git_root" && -d "$git_root/.git" ]]; then
    printf '%s\n' "$git_root"
    return 0
  fi

  return 1
}

