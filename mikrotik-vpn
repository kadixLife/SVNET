#!/usr/bin/env bash
set -uo pipefail

VERSION="1.0.0-alpha.1"

BASE_DIR="/opt/mikrotik-vpn"
CONFIG="/opt/mikrotik-vpn/config/mikrotik-vpn.conf"
LISTS="/opt/mikrotik-vpn/lists"
OUTPUT="/opt/mikrotik-vpn/output"
CLIENTS="/opt/mikrotik-vpn/output/clients"
MIKROTIK="/opt/mikrotik-vpn/output/mikrotik"
BACKUPS="/opt/mikrotik-vpn/backups"
DEVICES="/opt/mikrotik-vpn/devices"
CLI="/usr/local/bin/mikrotik-vpn"
REPO_DIR="${MIKROTIK_VPN_REPO_DIR:-/opt/mikrotik-vpn/repo}"
MIKROTIK_VPN_GIT_URL="${MIKROTIK_VPN_GIT_URL:-https://github.com/kadixLife/SVNET.git}"

OVPN_SERVICE="openvpn-server@mikrotik-vpn"
HTTP_SERVICE="mikrotik-vpn-http.service"
OVPN_SERVER_CONF="/etc/openvpn/server/mikrotik-vpn.conf"
HTTP_SERVICE_FILE="/etc/systemd/system/mikrotik-vpn-http.service"
EASYRSA_DIR="/etc/openvpn/easy-rsa"
LEGACY_KADI_HTTP_SERVICE="kadi-routeros-http.service"

PROJECT_NAME="MikroTik VPN"
SERVER_IP=""
WAN_IF="wan"
OVPN_NAME="mikrotik-vpn"
OVPN_IF="tun-mvpn"
CLIENT_NAME="mikrotik"
OVPN_PORT="1194"
OVPN_PROTO="udp"
VPN_NET="10.88.0.0/24"
VPN_CIDR="10.88.0.0/24"
VPN_SERVER_IP="10.88.0.1"
MIKROTIK_VPN_IP="10.88.0.2"
CLIENT_IP="10.88.0.2"
MIKROTIK_LAN="192.168.50.0/24"
MIKROTIK_WAN="pppoe-wan"
MIKROTIK_OVPN_IF="ovpn-mvpn"
MIKROTIK_LAN_DNS="192.168.50.1"
HTTP_PORT="8088"

if [[ -t 1 ]]; then
  RED=$'\033[31m'
  GREEN=$'\033[32m'
  YELLOW=$'\033[33m'
  BLUE=$'\033[34m'
  BOLD=$'\033[1m'
  RESET=$'\033[0m'
else
  RED=""
  GREEN=""
  YELLOW=""
  BLUE=""
  BOLD=""
  RESET=""
fi

ok() { printf '%s[OK]%s %s\n' "$GREEN" "$RESET" "$*"; }
warn() { printf '%s[WARN]%s %s\n' "$YELLOW" "$RESET" "$*"; }
fail() { printf '%s[FAIL]%s %s\n' "$RED" "$RESET" "$*"; }
info() { printf '%s[INFO]%s %s\n' "$BLUE" "$RESET" "$*"; }

menu_item() {
  local key="$1"
  local title="$2"
  local description="$3"
  printf '  %s) %s\n' "$key" "$title"
  printf '     %s\n\n' "$description"
}

menu_title() {
  local title="$1"
  printf '%s\n' "$title"
  printf '%s\n\n' "----------------------------------------"
}

pause() {
  echo
  read -r -p "Нажмите Enter, чтобы вернуться в меню..." _ || true
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

is_root() {
  [[ "${EUID:-$(id -u)}" -eq 0 ]]
}

require_root() {
  if ! is_root; then
    fail "Это действие нужно запустить от root."
    echo "Пример: sudo $CLI"
    return 1
  fi
}

confirm() {
  local prompt="$1"
  local answe
  read -r -p "$prompt [y/N] " answer || return 1
  [[ "$answer" == "y" || "$answer" == "Y" || "$answer" == "yes" || "$answer" == "YES" ]]
}

confirm_word() {
  local prompt="$1"
  local expected="$2"
  local answe
  echo "$prompt"
  read -r -p "Введите $expected для подтверждения: " answer || return 1
  [[ "$answer" == "$expected" ]]
}

detect_wan_if() {
  if command_exists ip; then
    ip -o -4 route show to default 2>/dev/null | awk '{print $5; exit}'
  fi
}

get_server_ip() {
  if [[ -n "${SERVER_IP:-}" && "${SERVER_IP:-}" != "AUTO" ]]; then
    printf '%s\n' "$SERVER_IP"
    return 0
  fi

  if command_exists curl; then
    SERVER_IP="$(curl -fsS4 --max-time 4 https://api.ipify.org 2>/dev/null || true)"
  fi

  if [[ -z "${SERVER_IP:-}" ]] && command_exists hostname; then
    SERVER_IP="$(hostname -I 2>/dev/null | awk '{print $1}')"
  fi

  if [[ -z "${SERVER_IP:-}" ]]; then
    SERVER_IP="SERVER_IP"
  fi

  printf '%s\n' "$SERVER_IP"
}

load_config() {
  if [[ -f "$CONFIG" ]]; then
    # shellcheck disable=SC1090
    source "$CONFIG"
  fi

  WAN_IF="${WAN_IF:-$(detect_wan_if)}"
  WAN_IF="${WAN_IF:-wan}"
  OVPN_NAME="${OVPN_NAME:-mikrotik-vpn}"
  OVPN_IF="${OVPN_IF:-tun-mvpn}"
  CLIENT_NAME="${CLIENT_NAME:-mikrotik}"
  OVPN_PORT="${OVPN_PORT:-1194}"
  OVPN_PROTO="${OVPN_PROTO:-udp}"
  VPN_NET="${VPN_NET:-${VPN_CIDR:-10.88.0.0/24}}"
  VPN_CIDR="${VPN_CIDR:-$VPN_NET}"
  VPN_SERVER_IP="${VPN_SERVER_IP:-10.88.0.1}"
  MIKROTIK_VPN_IP="${MIKROTIK_VPN_IP:-${CLIENT_IP:-10.88.0.2}}"
  CLIENT_IP="${CLIENT_IP:-$MIKROTIK_VPN_IP}"
  MIKROTIK_LAN="${MIKROTIK_LAN:-192.168.50.0/24}"
  MIKROTIK_WAN="${MIKROTIK_WAN:-pppoe-wan}"
  MIKROTIK_OVPN_IF="${MIKROTIK_OVPN_IF:-ovpn-mvpn}"
  MIKROTIK_LAN_DNS="${MIKROTIK_LAN_DNS:-192.168.50.1}"
  HTTP_PORT="${HTTP_PORT:-8088}"
  MIKROTIK_VPN_GIT_URL="${MIKROTIK_VPN_GIT_URL:-https://github.com/kadixLife/SVNET.git}"
  DEVICES="${DEVICES:-$BASE_DIR/devices}"
}

systemd_unit_exists() {
  command_exists systemctl && systemctl list-unit-files "$1" >/dev/null 2>&1
}

detect_mode() {
  if [[ -f "$CONFIG" || -f "$OVPN_SERVER_CONF" ]] || systemd_unit_exists "$OVPN_SERVICE"; then
    printf '%s\n' "Safe Upgrade Mode"
  else
    printf '%s\n' "Fresh Install Mode"
  fi
}

header() {
  local mode
  mode="$(detect_mode)"
  clear 2>/dev/null || true
  printf '%sMikroTik VPN Manager v%s%s\n' "$BOLD" "$VERSION" "$RESET"
  echo "Режим: $mode"
  echo
}

ensure_base_dirs() {
  mkdir -p "$BASE_DIR/config" "$LISTS" "$OUTPUT" "$CLIENTS" "$MIKROTIK" "$BACKUPS" "$DEVICES"
}

write_default_file() {
  local file="$1"
  local content="$2"
  if [[ ! -f "$file" ]]; then
    printf '%s\n' "$content" > "$file"
    ok "Создан список: $file"
  fi
}

