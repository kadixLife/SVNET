show_help() {
  cat <<TEXT
СвободаNET Manager v$VERSION

Usage:
  svnet                interactive menu
  svnet --version      show version
  svnet --status       run OpenVPN status checks
  svnet --doctor       run server diagnostics
  svnet --prepare-mikrotik
                          generate MikroTik .rsc files
  svnet --backup       create backup
  svnet --check-updates
                          check GitHub repository for updates
  svnet --update-dry-run
                          show files that would change during update
  svnet --update       update from Git repository
  svnet --publish-on   start HTTP publish for MikroTik setup
  svnet --publish-off  stop HTTP publish after MikroTik setup
  svnet --publish-status
                          show HTTP publish state and URLs
  svnet --repair-git-repo
                          rebuild /opt/svobodanet/repo as Git repository
  svnet --help         show this help
TEXT
}

main() {
  case "${1:-}" in
    --version|-v)
      echo "СвободаNET Manager v$VERSION"
      ;;
    --status)
      status_openvpn
      ;;
    --prepare-mikrotik)
      generate_mikrotik_configs
      ;;
    --doctor|--diagnostics)
      server_diagnostics
      ;;
    --backup)
      create_backup manual
      ;;
    --check-updates)
      check_updates
      ;;
    --update-dry-run)
      update_dry_run
      ;;
    --update)
      update_svobodanet
      ;;
    --publish-on)
      publish_on
      ;;
    --publish-off)
      publish_off
      ;;
    --publish-status)
      publish_status
      ;;
    --repair-git-repo)
      repair_git_repo
      ;;
    --help|-h)
      show_help
      ;;
    "")
      main_menu
      ;;
    *)
      fail "Неизвестный аргумент: $1"
      show_help
      return 2
      ;;
  esac
}

main "$@"
