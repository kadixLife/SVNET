  echo "Install path: $admin_repo"
  echo "Data path: $ADMIN_DIR"
  [[ -f "$env_file" ]] && echo "Env: exists" || echo "Env: missing"
  command_exists docker && echo "Docker: installed" || echo "Docker: missing"
  [[ -n "$compose_display" ]] && echo "Docker Compose: installed ($compose_display)" || echo "Docker Compose: missing"
  echo

  echo "Containers:"
  echo "- postgres: $(admin_container_state postgres)"
  echo "- backend: $(admin_container_state backend)"
  echo "- frontend: $(admin_container_state frontend)"
  echo

  echo "Health:"
  echo "- frontend: $frontend_code"
  echo "- backend: $backend_code"
  echo

  echo "Access:"
  echo "- Local: $(admin_frontend_url)"
  echo "- Home network: $(admin_lan_url) ($(admin_access_mode))"
