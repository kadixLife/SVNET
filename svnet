admin_start() {
  require_root || return 1
  load_config

  [[ -f "$(admin_env_file)" ]] || {
    fail "Admin .env не найден. Выполните: sudo svnet --admin-install"
    return 1
  }
  admin_ensure_docker || return 1
  admin_ensure_compose || return 1
  admin_compose_config_check || return 1
  run_admin_compose up -d || return 1
  admin_wait_health || true
  admin_print_access
}

admin_stop() {
  require_root || return 1
  load_config
  run_admin_compose down
  ok "Admin Panel остановлена. Volumes и $ADMIN_DIR не удалены."
}

admin_restart() {
  require_root || return 1
  load_config
  run_admin_compose restart || return 1
  admin_wait_health || true
}

admin_update() {
  require_root || return 1
  load_config
  warn "Будут обновлены только admin containers. OpenVPN, MikroTik и firewall не трогаются."
  admin_disk_preflight || return 1
  admin_compose_config_check || return 1
  info "Собираю новые backend/frontend images без остановки старых containers."
  if ! run_admin_compose build backend frontend; then
    fail "Admin Panel build failed. Старые containers не останавливались."
    echo "Если причина в свободном месте, выполните:"
    echo "  sudo svnet --admin-cleanup-docker"
    return 1
  fi

  info "Build OK. Пересоздаю admin containers."
  run_admin_compose up -d --force-recreate || {
    fail "docker compose up failed после успешной сборки."
    admin_show_runtime_logs
    return 1
  }

  if ! admin_verify_runtime; then
    fail "Admin Panel обновлена не полностью: health check не прошёл."
    admin_show_runtime_logs
    return 1
  fi

  ok "Admin Panel обновлена."
}

admin_cleanup_docker() {
  require_root || return 1
  load_config

  warn "Будет выполнена безопасная очистка cache/stopped/dangling данных."
  warn "Docker volumes с PostgreSQL данными НЕ удаляются."
  confirm "Запустить очистку apt/npm/docker cache без удаления volumes?" || return 0

  echo
  echo "До очистки:"
  command_exists df && df -h / || true
  command_exists docker && docker system df || true

  if command_exists apt-get; then
    apt-get clean || true
    ok "apt cache очищен."
  else
    warn "apt-get не найден, apt cache пропущен."
  fi

  if command_exists npm; then
    npm cache clean --force >/dev/null 2>&1 || true
    ok "npm cache очищен."
  else
    warn "npm не найден, npm cache пропущен."
  fi

  if command_exists docker; then
    docker builder prune -f || true
    docker container prune -f || true
    docker network prune -f || true
    docker image prune -f || true
    ok "Docker builder cache, stopped containers, unused networks и dangling images очищены."
    ok "Docker volumes не удалялись."
  else
    warn "docker не найден, Docker cleanup пропущен."
  fi

  echo
  echo "После очистки:"
  command_exists df && df -h / || true
  command_exists docker && docker system df || true
}

admin_backup_data_dir() {
