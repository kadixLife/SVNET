admin_module_dir() {
  printf '%s/admin\n' "$REPO_DIR"
}

admin_env_file() {
  printf '%s/.env\n' "$ADMIN_DIR"
}

admin_compose_file() {
  printf '%s/docker-compose.yml\n' "$(admin_module_dir)"
}

admin_compose_command() {
  if command_exists docker && docker compose version >/dev/null 2>&1; then
    printf '%s\n' "docker compose"
    return 0
  fi

  if command_exists docker-compose && docker-compose version >/dev/null 2>&1; then
    printf '%s\n' "docker-compose"
    return 0
  fi

  return 1
}

admin_compose_available() {
  admin_compose_command >/dev/null 2>&1
}

admin_compose_display() {
  local version
  if command_exists docker && docker compose version >/dev/null 2>&1; then
    version="$(docker compose version --short 2>/dev/null || docker compose version 2>/dev/null | awk '{print $NF; exit}')"
    version="${version#v}"
    printf 'docker compose v%s\n' "${version:-unknown}"
    return 0
  fi

  if command_exists docker-compose && docker-compose version >/dev/null 2>&1; then
    version="$(docker-compose version --short 2>/dev/null || docker-compose version 2>/dev/null | head -n1 | sed -E 's/.*version ([^, ]+).*/\1/')"
    version="${version#v}"
    printf 'docker-compose v%s\n' "${version:-unknown}"
    return 0
  fi

  return 1
}

run_admin_compose() {
  local admin_repo env_file compose_file
  local compose=()
  admin_repo="$(admin_module_dir)"
  env_file="$(admin_env_file)"
  compose_file="$(admin_compose_file)"

  if command_exists docker && docker compose version >/dev/null 2>&1; then
    compose=(docker compose)
  elif command_exists docker-compose && docker-compose version >/dev/null 2>&1; then
    compose=(docker-compose)
  else
    fail "Docker Compose не найден."
    return 1
  fi

  if [[ ! -d "$admin_repo" ]]; then
    fail "Admin module не найден: $admin_repo"
    return 1
  fi

  if [[ ! -f "$compose_file" ]]; then
    fail "Compose file не найден: $compose_file"
    return 1
  fi

  if [[ ! -f "$env_file" ]]; then
    fail "Admin .env не найден: $env_file"
    echo "Сначала выполните: sudo svnet --admin-install"
    return 1
  fi

  (
    cd "$admin_repo" || exit 1
    SVNET_ADMIN_ENV_FILE="$env_file" "${compose[@]}" -p svnet-admin -f "$compose_file" --env-file "$env_file" "$@"
  )
}

admin_check_os() {
  if [[ ! -f /etc/os-release ]]; then
    warn "OS не определена: /etc/os-release не найден."
    return 1
  fi

  # shellcheck disable=SC1091
  source /etc/os-release
  if [[ "${ID:-}" != "ubuntu" ]]; then
    warn "Поддерживается Ubuntu 22.04/24.04. Найдено: ${PRETTY_NAME:-unknown}"
    return 1
  fi

  case "${VERSION_ID:-}" in
    22.04|24.04)
      ok "OS: ${PRETTY_NAME:-Ubuntu $VERSION_ID}"
      ;;
    *)
      warn "Поддерживается Ubuntu 22.04/24.04. Найдено: ${PRETTY_NAME:-unknown}"
      return 1
      ;;
  esac
}

admin_install_docker_package() {
  if ! command_exists apt-get; then
    fail "apt-get не найден. Автоустановка Docker поддерживается только на Ubuntu."
    return 1
  fi

  info "Устанавливаю Docker через apt..."
  DEBIAN_FRONTEND=noninteractive apt-get update || return 1
  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io || return 1
  if command_exists systemctl; then
    systemctl enable --now docker >/dev/null 2>&1 || true
  fi
}

admin_install_compose_package() {
  if ! command_exists apt-get; then
    fail "apt-get не найден. Автоустановка Docker Compose plugin поддерживается только на Ubuntu."
    return 1
  fi

  info "Устанавливаю Docker Compose plugin через apt..."
  DEBIAN_FRONTEND=noninteractive apt-get update || return 1
  DEBIAN_FRONTEND=noninteractive apt-get install -y docker-compose-plugin || {
    warn "docker-compose-plugin недоступен, пробую docker-compose."
    DEBIAN_FRONTEND=noninteractive apt-get install -y docker-compose || return 1
  }
}

admin_ensure_docker() {
  local dry_run="${1:-}"
  if command_exists docker; then
    ok "Docker: $(docker --version 2>/dev/null)"
    return 0
  fi

  warn "Docker не найден."
  if [[ "$dry_run" == "--dry-run" ]]; then
    info "Dry-run: здесь был бы запрос на автоустановку Docker."
    return 0
  fi

  confirm "Docker не найден. Установить автоматически?" || return 1
  admin_install_docker_package
}

admin_ensure_compose() {
  local dry_run="${1:-}"
  local compose_display
  compose_display="$(admin_compose_display 2>/dev/null || true)"
  if [[ -n "$compose_display" ]]; then
    ok "Docker Compose: $compose_display"
    return 0
  fi

  warn "Docker Compose plugin не найден."
  if [[ "$dry_run" == "--dry-run" ]]; then
    info "Dry-run: здесь был бы запрос на автоустановку Docker Compose plugin."
    return 0
  fi

  confirm "Docker Compose plugin не найден. Установить автоматически?" || return 1
  admin_install_compose_package
  admin_compose_command >/dev/null
}

admin_random_secret() {
  local bytes="${1:-32}"
  if command_exists openssl; then
    openssl rand -hex "$bytes"
    return 0
  fi

  tr -dc 'A-Za-z0-9' < /dev/urandom | head -c "$((bytes * 2))"
  echo
}

admin_env_value() {
  local key="$1" file
  file="$(admin_env_file)"
  [[ -f "$file" ]] || return 1
  grep -E "^${key}=" "$file" | tail -n1 | cut -d= -f2- | sed -e 's/^"//' -e 's/"$//'
}

admin_set_env_value() {
  local key="$1" value="$2" file tmp
  file="$(admin_env_file)"
  tmp="$(mktemp)"

  if [[ -f "$file" ]] && grep -qE "^${key}=" "$file"; then
    sed "s|^${key}=.*|${key}=${value}|" "$file" > "$tmp" && mv "$tmp" "$file"
  else
    cat "$file" > "$tmp"
    printf '%s=%s\n' "$key" "$value" >> "$tmp"
    mv "$tmp" "$file"
  fi
}

admin_env_missing_or_placeholder() {
  local key="$1" value
  value="$(admin_env_value "$key" 2>/dev/null || true)"
  [[ -z "$value" || "$value" == CHANGE_* ]]
}

admin_set_env_default() {
  local key="$1" value="$2"
  if admin_env_missing_or_placeholder "$key"; then
    admin_set_env_value "$key" "$value"
  fi
}

admin_prepare_env() {
  local env_src env_dst postgres_user postgres_db postgres_password jwt_secret database_url
  env_src="$(admin_module_dir)/.env.example"
  env_dst="$(admin_env_file)"

  mkdir -p "$ADMIN_DIR"

  if [[ ! -f "$env_dst" ]]; then
    if [[ -f "$env_src" ]]; then
      cp "$env_src" "$env_dst"
    else
      touch "$env_dst"
    fi
    ok "Создан $env_dst"
  else
    ok "$env_dst уже существует, реальные значения не перезаписываю."
  fi

  chmod 600 "$env_dst" 2>/dev/null || true

  if admin_env_missing_or_placeholder JWT_SECRET; then
    jwt_secret="$(admin_random_secret 32)"
    admin_set_env_value JWT_SECRET "$jwt_secret"
    ok "JWT_SECRET сгенерирован."
  fi

  if admin_env_missing_or_placeholder POSTGRES_PASSWORD; then
    postgres_password="$(admin_random_secret 24)"
    admin_set_env_value POSTGRES_PASSWORD "$postgres_password"
    ok "POSTGRES_PASSWORD сгенерирован."
  else
    postgres_password="$(admin_env_value POSTGRES_PASSWORD)"
  fi

  admin_set_env_default NODE_ENV production
  admin_set_env_default FRONTEND_PORT "${FRONTEND_PORT:-3000}"
  admin_set_env_default BACKEND_PORT "${BACKEND_PORT:-3001}"
  admin_set_env_default FRONTEND_ORIGIN "${FRONTEND_ORIGIN:-http://localhost:3000}"
  admin_set_env_default NEXT_PUBLIC_API_BASE /api
  admin_set_env_default BACKEND_URL http://backend:3001
  admin_set_env_default AUTH_COOKIE_NAME svnet_admin_session
  admin_set_env_default COOKIE_SECURE false
  admin_set_env_default POSTGRES_USER "${POSTGRES_USER:-svnet_admin}"
  admin_set_env_default POSTGRES_DB "${POSTGRES_DB:-svnet_admin}"
  admin_set_env_default SVNET_CLI "$CLI"
  admin_set_env_default SVNET_BASE_DIR "$BASE_DIR"
  admin_set_env_default MIKROTIK_HOST "$MIKROTIK_VPN_IP"
  admin_set_env_default MIKROTIK_API_PORT 8728

  postgres_user="$(admin_env_value POSTGRES_USER 2>/dev/null || printf '%s' svnet_admin)"
  postgres_db="$(admin_env_value POSTGRES_DB 2>/dev/null || printf '%s' svnet_admin)"
  database_url="$(admin_env_value DATABASE_URL 2>/dev/null || true)"
  if [[ -z "$database_url" || "$database_url" == *CHANGE_* ]]; then
    admin_set_env_value DATABASE_URL "postgres://${postgres_user}:${postgres_password}@postgres:5432/${postgres_db}"
  fi

  chmod 600 "$env_dst" 2>/dev/null || true
}

admin_port() {
  local key="$1" fallback="$2" value
  value="$(admin_env_value "$key" 2>/dev/null || true)"
  printf '%s\n' "${value:-$fallback}"
}

admin_frontend_url() {
  printf 'http://127.0.0.1:%s\n' "$(admin_port FRONTEND_PORT 3000)"
}

admin_backend_url() {
  printf 'http://127.0.0.1:%s/api/health\n' "$(admin_port BACKEND_PORT 3001)"
}

admin_http_code() {
  local url="$1"
  local code
  command_exists curl || {
    printf 'curl-missing\n'
    return 1
  }
  code="$(curl -sS -o /dev/null -w '%{http_code}' --connect-timeout 3 --max-time 5 "$url" 2>/dev/null || true)"
  if [[ "$code" =~ ^[0-9]{3}$ ]]; then
    printf '%s\n' "$code"
  else
    printf '000\n'
  fi
}

admin_disk_free_kb() {
  command_exists df || return 1
  df -Pk / 2>/dev/null | awk 'NR == 2 {print $4}'
}

admin_format_kb() {
  local kb="$1"
  if command_exists numfmt; then
    numfmt --from-unit=1024 --to=iec --suffix=B "$kb" 2>/dev/null && return 0
  fi
  printf '%s KB\n' "$kb"
}

admin_disk_preflight() {
  local min_free_kb=$((2 * 1024 * 1024))
  local free_kb free_human

  echo "Disk preflight"
  echo

  if command_exists df; then
    df -h /
  else
    fail "df не найден, не могу проверить свободное место."
    return 1
  fi

  echo
  if command_exists docker; then
    docker system df || true
  else
    warn "docker не найден, docker system df пропущен."
  fi

  free_kb="$(admin_disk_free_kb || true)"
  if [[ -z "$free_kb" || ! "$free_kb" =~ ^[0-9]+$ ]]; then
    fail "Не удалось определить свободное место на /."
    return 1
  fi

  free_human="$(admin_format_kb "$free_kb")"
  if (( free_kb < min_free_kb )); then
    fail "Свободного места на / меньше 2 GB: $free_human"
    echo "Запустите безопасную очистку:"
    echo "  sudo svnet --admin-cleanup-docker"
    return 1
  fi

  ok "Свободное место на /: $free_human"
}

admin_lan_url() {
  load_config
  printf 'http://%s\n' "$ADMIN_ACCESS_HOST"
}

admin_access_mode() {
  if [[ -e "$ADMIN_NGINX_ENABLED" ]]; then
    printf '%s\n' "vpn-lan"
  else
    printf '%s\n' "local-only"
  fi
}

admin_http80_ss_lines() {
  command_exists ss || return 0
  ss -H -ltnp 2>/dev/null | grep -E "(:|\])${ADMIN_HTTP_PORT}[[:space:]]" || true
}

admin_vpn_http_listener_lines() {
  admin_http80_ss_lines | grep -F "${VPN_SERVER_IP}:${ADMIN_HTTP_PORT}" || true
}

admin_wildcard_http_listener_lines() {
  admin_http80_ss_lines | grep -E "(^|[[:space:]])(0\.0\.0\.0:${ADMIN_HTTP_PORT}|\*:${ADMIN_HTTP_PORT}|\[::\]:${ADMIN_HTTP_PORT}|:::${ADMIN_HTTP_PORT})([[:space:]]|$)" || true
}

admin_public_http_listener_lines() {
  local server_ip lines
  server_ip="$(get_server_ip)"
  lines="$(admin_http80_ss_lines)"
  {
    admin_wildcard_http_listener_lines
    if [[ -n "$server_ip" && "$server_ip" != "SERVER_IP" && "$server_ip" != "$VPN_SERVER_IP" ]]; then
      printf '%s\n' "$lines" | grep -F "${server_ip}:${ADMIN_HTTP_PORT}" || true
    fi
  } | sort -u
}

admin_unexpected_http80_listener_lines() {
  local lines
  lines="$(admin_http80_ss_lines)"
  [[ -n "$lines" ]] || return 0
  printf '%s\n' "$lines" | grep -vF "${VPN_SERVER_IP}:${ADMIN_HTTP_PORT}" || true
}

admin_http80_pids() {
  admin_http80_ss_lines | grep -oE 'pid=[0-9]+' 2>/dev/null | cut -d= -f2 | sort -u
}

admin_print_http80_processes() {
  local lines pids pid cwd
  lines="$(admin_http80_ss_lines)"
  [[ -n "$lines" ]] || return 0

  echo "$lines"
  mapfile -t pids < <(printf '%s\n' "$lines" | grep -oE 'pid=[0-9]+' 2>/dev/null | cut -d= -f2 | sort -u)
  for pid in "${pids[@]}"; do
    cwd="$(readlink -f "/proc/$pid/cwd" 2>/dev/null || true)"
    echo "PID: $pid"
    echo "CWD: ${cwd:-недоступно}"
  done
}

admin_nginx_active() {
  command_exists systemctl && systemctl is-active --quiet nginx
}

admin_public_ip_http_code() {
  local server_ip code
  server_ip="$(get_server_ip)"
  if [[ -z "$server_ip" || "$server_ip" == "SERVER_IP" || "$server_ip" == "$VPN_SERVER_IP" ]]; then
    printf '%s\n' "skipped"
    return 0
  fi

  if ! command_exists curl; then
    printf '%s\n' "curl-missing"
    return 0
  fi

  code="$(curl -sS -o /dev/null -w '%{http_code}' -I --connect-timeout 3 --max-time 5 "http://${server_ip}" 2>/dev/null || true)"
  printf '%s\n' "${code:-000}"
}

admin_warn_http_publish_listener() {
  load_config
  if http_port_is_listening; then
    warn "HTTP publish ${HTTP_PORT} сейчас слушает. Admin LAN access не зависит от 8088."
    echo "Если публикация конфигов не нужна, отключите её:"
    echo "sudo svnet --publish-off"
  else
    ok "HTTP publish ${HTTP_PORT}: offline or not listening"
  fi
}

admin_prepare_http_publish_before_lan_access() {
  load_config
  local public_lines

  if ! http_port_is_listening; then
    ok "HTTP publish ${HTTP_PORT}: offline or not listening"
    return 0
  fi

  public_lines="$(http_port_public_listener_lines)"
  if [[ -z "$public_lines" ]]; then
    warn "HTTP publish ${HTTP_PORT} слушает, но public/wildcard listener не найден. Admin LAN access от 8088 не зависит."
    print_http_listener_status no
    return 0
  fi

  warn "HTTP publish ${HTTP_PORT} слушает public/wildcard. Это не нужно для Admin LAN access."
  print_http_listener_status no

  if command_exists systemctl && systemctl is-active --quiet "$HTTP_SERVICE"; then
    confirm "Отключить временный HTTP publish перед продолжением?" || return 1
    publish_off || return 1
  else
    cleanup_http_port_legacy_units || true
  fi

  if [[ -n "$(http_port_public_listener_lines)" ]]; then
    fail "HTTP publish ${HTTP_PORT} всё ещё слушает public/wildcard. Выполните sudo svnet --cleanup-legacy-services или отключите старый service вручную."
    print_http_listener_status no
    return 1
  fi

  verify_http_publish_public_closed || return 1
}

admin_ensure_nginx() {
  if command_exists nginx; then
    ok "nginx: installed"
    return 0
  fi

  warn "nginx не найден."
  if ! command_exists apt-get; then
    fail "apt-get не найден. Установите nginx вручную."
    return 1
  fi

  confirm "Установить nginx автоматически через apt?" || return 1
  info "Устанавливаю nginx..."
  DEBIAN_FRONTEND=noninteractive apt-get update || return 1
  DEBIAN_FRONTEND=noninteractive apt-get install -y nginx || return 1
  command_exists systemctl && systemctl stop nginx >/dev/null 2>&1 || true
  ok "nginx установлен."
}

admin_move_nginx_default_sites() {
  local mode="${1:-all}"
  local f base dest moved=0

  mkdir -p "$ADMIN_NGINX_DISABLED_DIR"
  shopt -s nullglob
  for f in /etc/nginx/sites-enabled/default*; do
    [[ -e "$f" ]] || continue
    base="$(basename "$f")"
    if [[ "$mode" == "svnet-only" && "$base" != default.svnet-disabled_* ]]; then
      continue
    fi
    dest="$ADMIN_NGINX_DISABLED_DIR/$base"
    if [[ -e "$dest" ]]; then
      dest="$ADMIN_NGINX_DISABLED_DIR/${base}.$(date +%F_%H-%M-%S).$$"
    fi
    mv -f "$f" "$dest" || {
      shopt -u nullglob
      return 1
    }
    ok "nginx default site moved out of sites-enabled: $dest"
    moved=1
  done
  shopt -u nullglob

  if [[ "$moved" == "0" ]]; then
    if [[ "$mode" == "svnet-only" ]]; then
      ok "nginx SVNET-created default backups: not present in sites-enabled"
    else
      ok "nginx sites-enabled/default*: not present"
    fi
  fi
}

admin_disable_nginx_default_sites() {
  local defaults
  shopt -s nullglob
  defaults=(/etc/nginx/sites-enabled/default*)
  shopt -u nullglob

  if (( ${#defaults[@]} == 0 )); then
    ok "nginx default sites: not present in sites-enabled"
    return 0
  fi

  warn "Найдены nginx default* sites. Они часто слушают 0.0.0.0:80 или [::]:80."
  confirm "Переместить default* из sites-enabled в $ADMIN_NGINX_DISABLED_DIR?" || return 1
  admin_move_nginx_default_sites all
}

admin_write_nginx_config() {
  local frontend_port backend_port
  frontend_port="$(admin_port FRONTEND_PORT 3000)"
  backend_port="$(admin_port BACKEND_PORT 3001)"

  mkdir -p "$(dirname "$ADMIN_NGINX_AVAILABLE")" "$(dirname "$ADMIN_NGINX_ENABLED")"
  cat > "$ADMIN_NGINX_AVAILABLE" <<NGINX
server {
    listen ${VPN_SERVER_IP}:${ADMIN_HTTP_PORT};
    server_name ${ADMIN_ACCESS_HOST} ${VPN_SERVER_IP};

    client_max_body_size 2m;

    location /api/ {
        proxy_pass http://127.0.0.1:${backend_port}/api/;
        proxy_http_version 1.1;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_set_header Connection "";
    }

    location / {
        proxy_pass http://127.0.0.1:${frontend_port};
        proxy_http_version 1.1;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_set_header Connection "";
    }
}
NGINX

  ln -sfn "$ADMIN_NGINX_AVAILABLE" "$ADMIN_NGINX_ENABLED"
  ok "nginx config: $ADMIN_NGINX_AVAILABLE"
}

admin_nginx_forbidden_listens_from_dump() {
  local dump_file="$1"
  grep -En '^[[:space:]]*listen[[:space:]]+(80|0\.0\.0\.0:80|\*:80|\[::\]:80)([[:space:];]|$)' "$dump_file" 2>/dev/null || true
}

admin_nginx_bind_preflight() {
  local dump_file err_file forbidden
  dump_file="$(mktemp)"
  err_file="$(mktemp)"

  if ! nginx -T > "$dump_file" 2>"$err_file"; then
    fail "nginx -T failed"
    tail -n 40 "$err_file" 2>/dev/null || true
    rm -f "$dump_file" "$err_file"
    return 1
  fi

  forbidden="$(admin_nginx_forbidden_listens_from_dump "$dump_file")"
  if [[ -n "$forbidden" ]]; then
    fail "nginx config contains forbidden public/wildcard :${ADMIN_HTTP_PORT} listen"
    printf '%s\n' "$forbidden"
    rm -f "$dump_file" "$err_file"
    return 1
  fi

  rm -f "$dump_file" "$err_file"
  ok "nginx bind preflight: no wildcard/default :${ADMIN_HTTP_PORT} listen"
}

admin_reload_nginx() {
  nginx -t || {
    fail "nginx config test failed"
    return 1
  }

  if command_exists systemctl; then
    systemctl enable nginx >/dev/null 2>&1 || true
    if admin_nginx_active; then
      systemctl reload nginx || systemctl restart nginx || return 1
    else
      systemctl start nginx || return 1
    fi
  else
    nginx -s reload 2>/dev/null || nginx || return 1
  fi

  ok "nginx reloaded"
}

admin_reload_nginx_secure() {
  admin_nginx_bind_preflight || return 1
  admin_reload_nginx || return 1
}

persist_iptables_rules() {
  if command_exists netfilter-persistent; then
    netfilter-persistent save >/dev/null 2>&1 || warn "netfilter-persistent save не выполнен."
    return 0
  fi

  if command_exists iptables-save && [[ -d /etc/iptables ]]; then
    iptables-save > /etc/iptables/rules.v4 2>/dev/null || warn "Не удалось сохранить /etc/iptables/rules.v4."
    return 0
  fi

  warn "iptables rule применено, но persistence не найден. После reboot может потребоваться повторить команду."
}

admin_firewall_add_lan_rule() {
  local rule
  if ! command_exists iptables; then
    fail "iptables не найден."
    return 1
  fi

  rule=(-i "$OVPN_IF" -s "$VPN_CIDR" -p tcp --dport "$ADMIN_HTTP_PORT" -m comment --comment "$ADMIN_FIREWALL_COMMENT" -j ACCEPT)

  if iptables -C INPUT "${rule[@]}" 2>/dev/null; then
    ok "iptables INPUT $OVPN_IF tcp/$ADMIN_HTTP_PORT from $VPN_CIDR: есть"
  else
    iptables -I INPUT 1 "${rule[@]}" || return 1
    ok "iptables INPUT $OVPN_IF tcp/$ADMIN_HTTP_PORT from $VPN_CIDR: добавлено"
  fi

  persist_iptables_rules
}

admin_firewall_remove_lan_rule() {
  local rule removed=0
  if ! command_exists iptables; then
    warn "iptables не найден."
    return 0
  fi

  rule=(-i "$OVPN_IF" -s "$VPN_CIDR" -p tcp --dport "$ADMIN_HTTP_PORT" -m comment --comment "$ADMIN_FIREWALL_COMMENT" -j ACCEPT)
  while iptables -C INPUT "${rule[@]}" 2>/dev/null; do
    iptables -D INPUT "${rule[@]}" || return 1
    removed=1
  done

  if [[ "$removed" == "1" ]]; then
    ok "iptables INPUT $OVPN_IF tcp/$ADMIN_HTTP_PORT from $VPN_CIDR: удалено"
    persist_iptables_rules
  else
    ok "iptables INPUT $OVPN_IF tcp/$ADMIN_HTTP_PORT: SVNET rule не найдено"
  fi
}

admin_check_openvpn_ready() {
  local problems=0

  if command_exists systemctl && systemctl is-active --quiet "$OVPN_SERVICE"; then
    ok "OpenVPN service: active"
  else
    fail "OpenVPN service: не active"
    ((problems++))
  fi

  if command_exists ip && ip -4 -o addr show dev "$OVPN_IF" 2>/dev/null | grep -q " ${VPN_SERVER_IP}/"; then
    ok "$OVPN_IF: $VPN_SERVER_IP"
  else
    fail "$OVPN_IF не подтверждает IP $VPN_SERVER_IP"
    ((problems++))
  fi

  return "$problems"
}

admin_check_containers_running() {
  local service state problems=0

  [[ -f "$(admin_env_file)" ]] || {
    fail "Admin .env не найден. Выполните: sudo svnet --admin-install"
    return 1
  }

  admin_ensure_docker || return 1
  admin_ensure_compose || return 1
  admin_compose_config_check || return 1

  for service in postgres backend frontend; do
    state="$(admin_container_state "$service")"
    if [[ "$state" == "running" ]]; then
      ok "$service: running"
    else
      fail "$service: $state"
      ((problems++))
    fi
  done

  return "$problems"
}

admin_mikrotik_dns_generated() {
  grep -q "name=\"${ADMIN_ACCESS_HOST}\" address=${VPN_SERVER_IP}" "$MIKROTIK/svnet-mikrotik-install.rsc" 2>/dev/null
}

admin_print_mikrotik_apply_hint() {
  echo
  echo "MikroTik DNS update:"
  echo "1. Временно включите публикацию, если будете импортировать файл через RouterOS fetch:"
  echo "   sudo svnet --publish-on"
  echo "2. На MikroTik выполните команду импорта:"
  show_mikrotik_install_command
  echo "3. После импорта отключите публикацию:"
  echo "   sudo svnet --publish-off"
}

admin_verify_lan_access() {
  local code public_code public_lines unexpected_lines problems=0

  code="$(http_status_code "http://${VPN_SERVER_IP}")"
  if [[ "$code" == "200" || "$code" == "302" ]]; then
    ok "curl http://${VPN_SERVER_IP}: HTTP $code"
  else
    fail "curl http://${VPN_SERVER_IP}: HTTP $code"
    ((problems++))
  fi

  if [[ -n "$(admin_vpn_http_listener_lines)" ]]; then
    ok "${VPN_SERVER_IP}:${ADMIN_HTTP_PORT}: listening"
  else
    fail "${VPN_SERVER_IP}:${ADMIN_HTTP_PORT}: not listening"
    ((problems++))
  fi

  unexpected_lines="$(admin_unexpected_http80_listener_lines)"
  if [[ -n "$unexpected_lines" ]]; then
    fail "Unexpected :${ADMIN_HTTP_PORT} listener found. Allowed only ${VPN_SERVER_IP}:${ADMIN_HTTP_PORT}."
    printf '%s\n' "$unexpected_lines"
    ((problems++))
  else
    ok "No unexpected :${ADMIN_HTTP_PORT} listener"
  fi

  public_lines="$(admin_public_http_listener_lines)"
  if [[ -n "$public_lines" ]]; then
    fail "Public IP/${ADMIN_HTTP_PORT}: найден listener. Admin Panel не должен слушать public HTTP."
    printf '%s\n' "$public_lines"
    ((problems++))
  else
    ok "Public IP:${ADMIN_HTTP_PORT}: not listening"
  fi

  public_code="$(admin_public_ip_http_code)"
  case "$public_code" in
    000)
      ok "curl public IP:${ADMIN_HTTP_PORT}: refused/timeout"
      ;;
    skipped)
      warn "curl public IP:${ADMIN_HTTP_PORT}: skipped, public IP не определён"
      ;;
    curl-missing)
      warn "curl public IP:${ADMIN_HTTP_PORT}: curl не найден"
      ;;
    *)
      fail "curl public IP:${ADMIN_HTTP_PORT}: HTTP $public_code"
      ((problems++))
      ;;
  esac

  return "$problems"
}

admin_access_status() {
  load_config

  local mode frontend_code backend_code vpn_code public_code public_lines wildcard_lines unexpected_lines
  mode="$(admin_access_mode)"
  frontend_code="$(http_status_code "$(admin_frontend_url)")"
  backend_code="$(http_status_code "$(admin_backend_url)")"
  vpn_code="$(http_status_code "http://${VPN_SERVER_IP}")"

  echo "SVNET Admin Panel access status"
  echo
  ok "Mode: $mode"
  echo "Access modes:"
  echo "- local-only: only 127.0.0.1, default after install"
  echo "- vpn-lan: ${VPN_SERVER_IP}:${ADMIN_HTTP_PORT} + 127.0.0.1"
  echo "- public-https: reserved for future, disabled"
  echo

  echo "Local access:"
  echo "- Frontend 127.0.0.1:$(admin_port FRONTEND_PORT 3000): $frontend_code"
  echo "- Backend 127.0.0.1:$(admin_port BACKEND_PORT 3001): $backend_code"
  echo

  echo "Home network access:"
  echo "- URL: $(admin_lan_url)"
  echo "- VPN gateway: http://${VPN_SERVER_IP}"

  if command_exists systemctl && systemctl is-active --quiet nginx; then
    ok "nginx: active"
  else
    if [[ "$mode" == "vpn-lan" ]]; then
      fail "nginx: inactive"
    else
      ok "nginx: inactive"
    fi
  fi

  if [[ -n "$(admin_vpn_http_listener_lines)" ]]; then
    ok "${VPN_SERVER_IP}:${ADMIN_HTTP_PORT}: listening"
    admin_print_http80_processes
  else
    wildcard_lines="$(admin_wildcard_http_listener_lines)"
    if [[ "$vpn_code" == "200" || "$vpn_code" == "302" ]] && [[ -n "$wildcard_lines" ]]; then
      fail "${VPN_SERVER_IP}:${ADMIN_HTTP_PORT}: responds through wildcard binding, insecure"
      printf '%s\n' "$wildcard_lines"
    elif [[ "$mode" == "vpn-lan" ]]; then
      fail "${VPN_SERVER_IP}:${ADMIN_HTTP_PORT}: not listening"
    else
      ok "${VPN_SERVER_IP}:${ADMIN_HTTP_PORT}: not listening"
    fi
  fi

  unexpected_lines="$(admin_unexpected_http80_listener_lines)"
  if [[ -n "$unexpected_lines" ]]; then
    warn "Unexpected :${ADMIN_HTTP_PORT} listener found. Allowed Admin bind is ${VPN_SERVER_IP}:${ADMIN_HTTP_PORT}."
    printf '%s\n' "$unexpected_lines"
  else
    ok "No unexpected :${ADMIN_HTTP_PORT} listener"
  fi

  wildcard_lines="$(admin_wildcard_http_listener_lines)"
  if [[ -n "$wildcard_lines" ]]; then
    fail "Wildcard :${ADMIN_HTTP_PORT} listener found"
    printf '%s\n' "$wildcard_lines"
  else
    ok "No wildcard :${ADMIN_HTTP_PORT} listener"
  fi

  public_lines="$(admin_public_http_listener_lines)"
  if [[ -n "$public_lines" ]]; then
    warn "Найден listener на public/wildcard :${ADMIN_HTTP_PORT}. Это небезопасно для Admin Panel."
    printf '%s\n' "$public_lines"
  else
    ok "Public IP:${ADMIN_HTTP_PORT}: not listening"
  fi

  public_code="$(admin_public_ip_http_code)"
  case "$public_code" in
    000) ok "curl public IP:${ADMIN_HTTP_PORT}: refused/timeout" ;;
    skipped) warn "curl public IP:${ADMIN_HTTP_PORT}: skipped, public IP не определён" ;;
    curl-missing) warn "curl public IP:${ADMIN_HTTP_PORT}: curl не найден" ;;
    *) fail "curl public IP:${ADMIN_HTTP_PORT}: HTTP $public_code" ;;
  esac

  if admin_mikrotik_dns_generated; then
    ok "MikroTik DNS static: ${ADMIN_ACCESS_HOST} -> ${VPN_SERVER_IP} есть в generated .rsc"
  else
    warn "MikroTik DNS static required: ${ADMIN_ACCESS_HOST} -> ${VPN_SERVER_IP}. Выполните sudo svnet --prepare-mikrotik или --admin-enable-lan-access."
  fi
}

admin_enable_lan_access() {
  require_root || return 1
  load_config

  echo "Enable SVNET Admin Panel access from home network"
  echo
  info "Admin Panel не будет открыт на public IP. Nginx должен слушать только ${VPN_SERVER_IP}:${ADMIN_HTTP_PORT}."
  admin_prepare_http_publish_before_lan_access || return 1

  admin_check_openvpn_ready || return 1
  admin_check_containers_running || return 1
  admin_ensure_nginx || return 1
  admin_disable_nginx_default_sites || return 1
  admin_write_nginx_config || return 1
  if ! admin_reload_nginx_secure; then
    admin_rollback_nginx_admin_access
    return 1
  fi

  if ! admin_verify_lan_access; then
    admin_rollback_nginx_admin_access
    return 1
  fi

  admin_firewall_add_lan_rule || {
    admin_rollback_nginx_admin_access
    return 1
  }

  info "Обновляю MikroTik .rsc, чтобы добавить DNS ${ADMIN_ACCESS_HOST} -> ${VPN_SERVER_IP}."
  generate_mikrotik_configs || return 1
  admin_print_mikrotik_apply_hint

  echo
  admin_verify_lan_access || return 1
  admin_warn_http_publish_listener
  echo
  ok "Admin Panel доступна из домашней сети: $(admin_lan_url)"
  ok "Developer local access сохранён: $(admin_frontend_url)"
}

admin_rollback_nginx_admin_access() {
  warn "Rollback: отключаю nginx admin access, потому что bind проверка не прошла."
  rm -f "$ADMIN_NGINX_ENABLED" 2>/dev/null || true
  if command_exists nginx; then
    if nginx -t >/dev/null 2>&1; then
      if command_exists systemctl && admin_nginx_active; then
        systemctl reload nginx >/dev/null 2>&1 || systemctl restart nginx >/dev/null 2>&1 || true
      else
        nginx -s reload >/dev/null 2>&1 || true
      fi
    fi
  fi
  admin_firewall_remove_lan_rule || true
}

admin_disable_lan_access() {
  require_root || return 1
  load_config

  echo "Disable SVNET Admin Panel home network access"
  echo

  if [[ -e "$ADMIN_NGINX_ENABLED" ]]; then
    rm -f "$ADMIN_NGINX_ENABLED"
    ok "nginx site disabled: $ADMIN_NGINX_ENABLED"
  else
    ok "nginx site already disabled"
  fi

  admin_move_nginx_default_sites svnet-only || return 1

  if command_exists nginx; then
    admin_nginx_bind_preflight || return 1
    nginx -t || return 1
    if command_exists systemctl && admin_nginx_active; then
      systemctl reload nginx || systemctl restart nginx || return 1
    else
      nginx -s reload 2>/dev/null || true
    fi
  fi

  admin_firewall_remove_lan_rule || return 1
  ok "Admin containers не остановлены. Local access сохранён: $(admin_frontend_url)"
  echo
  admin_access_status
}

admin_fix_nginx_bind() {
  require_root || return 1
  load_config

  echo "Fix SVNET Admin Panel nginx bind"
  echo

  admin_check_openvpn_ready || return 1
  admin_ensure_nginx || return 1
  admin_warn_http_publish_listener
  admin_move_nginx_default_sites all || return 1
  admin_write_nginx_config || return 1

  if ! admin_reload_nginx_secure; then
    admin_rollback_nginx_admin_access
    return 1
  fi

  if ! admin_verify_lan_access; then
    admin_rollback_nginx_admin_access
    return 1
  fi

  ok "nginx слушает только безопасный VPN bind для Admin Panel."
}

admin_container_state() {
  local service="$1" id state
  if ! command_exists docker || ! admin_compose_command >/dev/null 2>&1; then
    printf 'missing\n'
    return 0
  fi

  id="$(run_admin_compose ps -q "$service" 2>/dev/null || true)"
  if [[ -z "$id" ]]; then
    printf 'missing\n'
    return 0
  fi

  state="$(docker inspect -f '{{.State.Status}}' "$id" 2>/dev/null || true)"
  printf '%s\n' "${state:-missing}"
}

admin_print_access() {
  local server_ip frontend_url
  server_ip="$(get_server_ip)"
  frontend_url="$(admin_frontend_url)"
