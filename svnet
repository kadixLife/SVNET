resolve_update_repo() {
  load_config
  local script_dir git_root
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

  if [[ -d "$REPO_DIR" && ! -d "$REPO_DIR/.git" ]]; then
    warn "Repo folder exists, but it is not a Git repository."
    echo "Repair: sudo svnet --repair-git-repo"
    return 1
  fi

  if [[ -d "$REPO_DIR/.git" ]]; then
    printf '%s\n' "$REPO_DIR"
    return 0
  fi

  if [[ -d "$script_dir/.git" ]]; then
    printf '%s\n' "$script_dir"
    return 0
  fi

  git_root="$(git -C "$script_dir" rev-parse --show-toplevel 2>/dev/null || true)"
  if [[ -n "$git_root" && -d "$git_root/.git" ]]; then
    printf '%s\n' "$git_root"
    return 0
  fi

  return 1
}

read_local_version() {
  local repo="$1"
  load_config

  if [[ -n "${SVNET_VERSION:-}" ]]; then
    printf '%s\n' "$SVNET_VERSION"
  elif [[ -f "$repo/VERSION" ]]; then
    tr -d '[:space:]' < "$repo/VERSION"
  else
    "$CLI" --version 2>/dev/null | awk '{print $NF; exit}' || printf '%s\n' "$VERSION"
  fi
}

read_remote_version() {
  local repo="$1"
  git -C "$repo" show origin/main:VERSION 2>/dev/null | tr -d '[:space:]' || true
}

collect_update_info() {
  local fetch="${1:-yes}"

  UPDATE_REPO="$(resolve_update_repo)" || {
    fail "Git-репозиторий СвободаNET не найден."
    if [[ -d "$REPO_DIR" && ! -d "$REPO_DIR/.git" ]]; then
      warn "Repo folder exists, but it is not a Git repository."
      echo "Repair: sudo svnet --repair-git-repo"
      echo
    fi
    cat <<TEXT
Проверьте один из вариантов:
- /opt/svobodanet/repo должен быть Git-репозиторием
- либо запускайте svnet из клонированного репозитория

Для ручного обновления:
git clone https://github.com/kadixLife/SVNET.git
cd SVNET
sudo ./install.sh
TEXT
    return 1
  }

  if ! command_exists git; then
    fail "git не найден."
    return 1
  fi

  UPDATE_REMOTE_URL="$(git -C "$UPDATE_REPO" remote get-url origin 2>/dev/null || true)"
  if [[ -z "$UPDATE_REMOTE_URL" ]]; then
    fail "Git remote origin не настроен в $UPDATE_REPO."
    return 1
  fi

  if [[ "$fetch" == "yes" ]]; then
    git -C "$UPDATE_REPO" fetch origin || {
      fail "git fetch origin не выполнен."
      return 1
    }
  fi

  UPDATE_LOCAL_VERSION="$(read_local_version "$UPDATE_REPO")"
  UPDATE_REMOTE_VERSION="$(read_remote_version "$UPDATE_REPO")"
  UPDATE_REMOTE_VERSION="${UPDATE_REMOTE_VERSION:-неизвестно}"
  UPDATE_LOCAL_COMMIT_FULL="$(git -C "$UPDATE_REPO" rev-parse HEAD 2>/dev/null || true)"
  UPDATE_REMOTE_COMMIT_FULL="$(git -C "$UPDATE_REPO" rev-parse origin/main 2>/dev/null || true)"
  UPDATE_LOCAL_COMMIT="$(git -C "$UPDATE_REPO" rev-parse --short HEAD 2>/dev/null || true)"
  UPDATE_REMOTE_COMMIT="$(git -C "$UPDATE_REPO" rev-parse --short origin/main 2>/dev/null || true)"
  UPDATE_DIRTY="$(git -C "$UPDATE_REPO" status --porcelain 2>/dev/null || true)"
  UPDATE_STATUS="unknown"

  if [[ -z "$UPDATE_LOCAL_COMMIT_FULL" || -z "$UPDATE_REMOTE_COMMIT_FULL" ]]; then
    UPDATE_STATUS="unknown"
  elif [[ "$UPDATE_LOCAL_COMMIT_FULL" == "$UPDATE_REMOTE_COMMIT_FULL" ]]; then
    UPDATE_STATUS="current"
  elif git -C "$UPDATE_REPO" merge-base --is-ancestor "$UPDATE_LOCAL_COMMIT_FULL" "$UPDATE_REMOTE_COMMIT_FULL" 2>/dev/null; then
    UPDATE_STATUS="update_available"
  elif git -C "$UPDATE_REPO" merge-base --is-ancestor "$UPDATE_REMOTE_COMMIT_FULL" "$UPDATE_LOCAL_COMMIT_FULL" 2>/dev/null; then
    UPDATE_STATUS="local_ahead"
  else
    UPDATE_STATUS="diverged"
  fi
}

print_update_summary() {
  echo "Установленная версия: $UPDATE_LOCAL_VERSION"
  echo "Версия в репозитории: $UPDATE_REMOTE_VERSION"
  echo "Локальный commit: ${UPDATE_LOCAL_COMMIT:-неизвестно}"
  echo "Удалённый commit: ${UPDATE_REMOTE_COMMIT:-неизвестно}"
  echo "Git remote: $UPDATE_REMOTE_URL"
  echo "Путь repo: $UPDATE_REPO"
  if [[ -n "$UPDATE_DIRTY" ]]; then
    echo "Локальные изменения: есть"
  else
    echo "Локальные изменения: нет"
  fi

  case "$UPDATE_STATUS" in
    current) echo "Статус: установлена актуальная версия" ;;
    update_available) echo "Статус: доступно обновление" ;;
    local_ahead) echo "Статус: локальная версия новее GitHub или не запушена" ;;
    diverged) echo "Статус: локальная и удалённая истории разошлись" ;;
    *) echo "Статус: не удалось определить" ;;
  esac
}

show_update_changes() {
  collect_update_info yes || return 1
  echo "Что изменилось:"
  echo

  if [[ "$UPDATE_STATUS" != "update_available" ]]; then
    info "Нет удалённых изменений для показа."
    return 0
  fi

  local commits
  commits="$(git -C "$UPDATE_REPO" log --oneline HEAD..origin/main 2>/dev/null || true)"
  if [[ -n "$commits" ]]; then
    printf '%s\n' "$commits" | sed 's/^/- /'
  elif git -C "$UPDATE_REPO" show origin/main:CHANGELOG.md >/dev/null 2>&1; then
    git -C "$UPDATE_REPO" show origin/main:CHANGELOG.md | sed -n '1,80p'
  else
    warn "CHANGELOG и список commits недоступны."
  fi
}

check_updates() {
  collect_update_info yes || return 1
  print_update_summary
  echo

  case "$UPDATE_STATUS" in
    current)
      ok "Установлена актуальная версия СвободаNET."
      ;;
    update_available)
      info "Доступна новая версия СвободаNET."
      echo
      show_update_changes || true
      echo
      if confirm "Обновить сейчас?"; then
        update_svobodanet
      fi
      ;;
    local_ahead)
      warn "Локальная версия новее origin/main. Push или проверьте ветку перед обновлением."
      ;;
    diverged)
      fail "Локальные и удалённые изменения разошлись. Автоматическое обновление остановлено."
      ;;
    *)
      fail "Не удалось определить состояние обновления."
      ;;
  esac
}

update_dry_run() {
  collect_update_info yes || return 1
  print_update_summary
  echo

  if [[ "$UPDATE_STATUS" != "update_available" ]]; then
    ok "Удалённых изменений для применения нет."
    echo "Сервисы не будут перезапущены."
    echo "Файлы не будут изменены."
    return 0
  fi

  echo "Будут изменены файлы:"
  local files
  files="$(git -C "$UPDATE_REPO" diff --name-only HEAD..origin/main 2>/dev/null || true)"
  if [[ -n "$files" ]]; then
    printf '%s\n' "$files" | sed 's/^/- /'
  else
    warn "Список файлов получить не удалось."
  fi
  echo
  echo "Сервисы не будут перезапущены."
  echo "Файлы не будут изменены."
}

update_config_version() {
  local new_version="$1"
  [[ -f "$CONFIG" ]] || return 0

  local tmp
  tmp="${CONFIG}.tmp.$$"
  if grep -q '^SVNET_VERSION=' "$CONFIG"; then
    sed "s/^SVNET_VERSION=.*/SVNET_VERSION=\"$new_version\"/" "$CONFIG" > "$tmp" && mv -f "$tmp" "$CONFIG"
  else
    printf '\nSVNET_VERSION="%s"\n' "$new_version" >> "$CONFIG"
  fi
}

run_pending_migrations() {
  local repo="$1"
  local marker_dir="$BASE_DIR/config/migrations-applied"
  local migration name

  [[ -d "$repo/migrations" ]] || return 0
  mkdir -p "$marker_dir"

  for migration in "$repo"/migrations/*.sh; do
    [[ -f "$migration" ]] || continue
    name="$(basename "$migration")"
    [[ -f "$marker_dir/$name" ]] && continue
    CONFIG_DIR="$BASE_DIR/config" LISTS_DIR="$LISTS" bash "$migration" || return 1
    touch "$marker_dir/$name"
    ok "Migration applied: $name"
  done
}

update_svobodanet() {
  require_root || return 1
  collect_update_info yes || return 1

  if [[ -n "$UPDATE_DIRTY" ]]; then
    fail "В репозитории есть локальные изменения. Автоматическое обновление остановлено."
    echo "Проверьте: git -C \"$UPDATE_REPO\" status"
    return 1
  fi

  if [[ "$UPDATE_STATUS" == "current" ]]; then
    ok "Установлена актуальная версия СвободаNET."
    return 0
  fi

  if [[ "$UPDATE_STATUS" != "update_available" ]]; then
    fail "Обновление невозможно без fast-forward."
    echo "Проверьте: git -C \"$UPDATE_REPO\" status"
    return 1
  fi

  print_update_summary
  echo
  show_update_changes || true
  echo
  confirm "Начать безопасное обновление?" || {
    info "Обновление отменено."
    return 0
  }

  create_backup "pre-update" || return 1

  if ! git -C "$UPDATE_REPO" pull --ff-only origin main; then
    fail "Невозможно выполнить fast-forward update."
    echo "Локальные изменения мешают обновлению."
    echo "Сначала проверьте: git -C \"$UPDATE_REPO\" status"
    echo "Rollback: sudo svnet -> Backup / Restore"
    return 1
  fi

  if [[ -x "$UPDATE_REPO/tests/bash-syntax.sh" ]]; then
    bash "$UPDATE_REPO/tests/bash-syntax.sh" || return 1
  fi
  bash -n "$UPDATE_REPO/svnet" || return 1
  install -m 0755 "$UPDATE_REPO/svnet" "$CLI"

  local new_version
  new_version="$(tr -d '[:space:]' < "$UPDATE_REPO/VERSION" 2>/dev/null || printf '%s' "$VERSION")"
  update_config_version "$new_version"
  run_pending_migrations "$UPDATE_REPO" || return 1

  echo
  "$CLI" --status || true

  local openvpn_state http_state mt_state
  openvpn_state="unknown"
  http_state="offline"
  mt_state="WARN"
  command_exists systemctl && openvpn_state="$(systemctl is-active "$OVPN_SERVICE" 2>/dev/null || true)"
  command_exists systemctl && systemctl is-active --quiet "$HTTP_SERVICE" && http_state="active"
  [[ -s "$MIKROTIK/svnet-mikrotik-split-vpnfirst.rsc" && -s "$MIKROTIK/svnet-mikrotik-install.rsc" ]] && mt_state="OK"

  echo
  ok "СвободаNET успешно обновлён."
  echo "Версия: $new_version"
  echo "OpenVPN: $openvpn_state"
  echo "HTTP publish: $http_state"
  echo "MikroTik configs: $mt_state"
}

