admin_remove() {
  require_root || return 1
  load_config
  warn "Удаление Admin Panel не должно затрагивать OpenVPN, MikroTik и firewall."
  confirm_word "Первое подтверждение удаления Admin Panel." "REMOVE_ADMIN" || return 0
  confirm_word "Второе подтверждение удаления Admin Panel." "REMOVE_ADMIN" || return 0

  if confirm "Удалить Docker volumes с PostgreSQL данными?"; then
    run_admin_compose down -v || true
  else
    run_admin_compose down || true
    ok "Docker volumes сохранены."
  fi

  if confirm "Удалить $ADMIN_DIR с .env и служебными файлами?"; then
    if [[ "$ADMIN_DIR" == "/opt/svobodanet-admin" ]]; then
      rm -rf "$ADMIN_DIR"
      ok "$ADMIN_DIR удалён."
    else
      fail "ADMIN_DIR выглядит нестандартно, удаление остановлено: $ADMIN_DIR"
      return 1
    fi
  else
    ok "$ADMIN_DIR сохранён."
  fi
}

