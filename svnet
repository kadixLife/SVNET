doctor_git_repo() {
  load_config
  echo "### Git repository"

  if [[ -d "$REPO_DIR" ]]; then
    ok "Repo folder exists: $REPO_DIR"
  else
    warn "Repo folder not found: $REPO_DIR"
    echo "Repair: sudo svnet --repair-git-repo"
    echo
    return 0
  fi

  if [[ -d "$REPO_DIR/.git" ]]; then
    ok "Git metadata exists: $REPO_DIR/.git"
  else
    warn "Repo folder exists, but it is not a Git repository."
    echo "Repair: sudo svnet --repair-git-repo"
    echo
    return 0
  fi

  if ! command_exists git; then
    warn "git не найден. Команды обновления работать не будут."
    echo "Repair after installing git: sudo svnet --repair-git-repo"
    echo
    return 0
  fi

  local remote
  remote="$(git -C "$REPO_DIR" remote get-url origin 2>/dev/null || true)"
  if [[ -n "$remote" ]]; then
    ok "git remote origin: $remote"
  else
    warn "git remote origin не настроен."
    echo "Repair: sudo svnet --repair-git-repo"
    echo
    return 0
  fi

  if git -C "$REPO_DIR" fetch origin >/dev/null 2>&1; then
    ok "git fetch origin: OK"
  else
    warn "git fetch origin не выполнен."
  fi
  echo
}

repair_git_repo() {
  require_root || return 1
  load_config

  if ! command_exists git; then
    fail "git не найден. Установите git и повторите repair."
    echo "Пример: sudo apt install -y git"
    return 1
  fi

  local ts backup
  ts="$(date +%Y-%m-%d_%H-%M-%S)"
  backup="${REPO_DIR}.nogit.backup_${ts}"

  mkdir -p "$(dirname "$REPO_DIR")"

  if [[ -e "$REPO_DIR" ]]; then
    if [[ -e "$backup" ]]; then
      backup="${backup}_$$"
    fi
    mv "$REPO_DIR" "$backup"
    ok "Старый repo сохранён: $backup"
  fi

  git clone "$SVNET_GIT_URL" "$REPO_DIR" || {
    fail "Не удалось клонировать $SVNET_GIT_URL в $REPO_DIR."
    [[ -n "${backup:-}" ]] && warn "Старый repo сохранён здесь: $backup"
    return 1
  }

  if [[ -f "$REPO_DIR/tests/bash-syntax.sh" ]]; then
    bash "$REPO_DIR/tests/bash-syntax.sh" || return 1
  else
    bash -n "$REPO_DIR/svnet" || return 1
  fi

  ok "Git repo восстановлен: $REPO_DIR"
  info "OpenVPN, firewall, MikroTik configs и пользовательские списки не менялись."
}

