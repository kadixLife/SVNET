  local admin_repo env_file compose_display frontend_code backend_code
  admin_repo="$(admin_module_dir)"
  env_file="$(admin_env_file)"
  compose_display="$(admin_compose_display 2>/dev/null || true)"
  frontend_code="$(admin_http_code "$(admin_frontend_url)")"
