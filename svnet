admin_wait_health() {
  local attempt frontend_code backend_code frontend_url backend_url
  frontend_url="$(admin_frontend_url)"
  backend_url="$(admin_backend_url)"

  for attempt in {1..30}; do
    frontend_code="$(admin_http_code "$frontend_url")"
    backend_code="$(admin_http_code "$backend_url")"
    if [[ "$frontend_code" == "200" && "$backend_code" == "200" ]]; then
      ok "frontend health: 200"
      ok "backend health: 200"
      return 0
    fi
    info "Ждём Admin Panel health... попытка $attempt/30 (frontend=$frontend_code backend=$backend_code)"
    sleep 2
  done

  warn "Admin Panel health не подтвердился."
  echo "frontend: $(admin_http_code "$frontend_url")"
  echo "backend: $(admin_http_code "$backend_url")"
  return 1
}

admin_verify_runtime() {
  local problems=0 state

  state="$(admin_container_state backend)"
  if [[ "$state" == "running" ]]; then
    ok "backend container: running"
  else
    fail "backend container: $state"
    ((problems++))
  fi

  state="$(admin_container_state frontend)"
  if [[ "$state" == "running" ]]; then
    ok "frontend container: running"
  else
    fail "frontend container: $state"
    ((problems++))
  fi

  admin_wait_health || ((problems++))
  return "$problems"
}

admin_show_runtime_logs() {
  warn "Последние логи backend/frontend:"
  run_admin_compose logs --tail=120 backend frontend || true
}

admin_check_prereqs() {
  local dry_run="${1:-}" admin_repo
  admin_repo="$(admin_module_dir)"

  admin_check_os || return 1

  if [[ -d "$admin_repo" ]]; then
    ok "Admin module: $admin_repo"
  else
    fail "Admin module не найден: $admin_repo"
    echo "Проверьте, что /opt/svobodanet/repo обновлён."
    return 1
  fi

  admin_ensure_docker "$dry_run" || return 1
  admin_ensure_compose "$dry_run" || return 1
}

admin_compose_config_check() {
  local err_file
  err_file="$(mktemp)"
  info "Проверяю docker compose config..."
  if ! run_admin_compose config >/dev/null 2>"$err_file"; then
    fail "docker compose config failed"
    echo "Последние строки ошибки:"
    tail -n 40 "$err_file" 2>/dev/null || true
    rm -f "$err_file"
    return 1
  fi
  rm -f "$err_file"
  ok "docker compose config: OK"
}

admin_install() {
  require_root || return 1
  load_config

  local dry_run="${1:-}"

  echo "GUI Admin Panel v$VERSION"
  echo

  admin_check_prereqs "$dry_run" || return 1

  if [[ "$dry_run" == "--dry-run" ]]; then
    info "Dry-run: .env, Docker containers и volumes не менялись."
    return 0
  fi

  admin_prepare_env || return 1
  admin_compose_config_check || return 1

  echo
  ok "Admin Panel подготовлена."
  if confirm "Запустить сейчас?"; then
    run_admin_compose up -d --build || return 1
    admin_wait_health || true
    echo
    ok "SVNET Admin Panel установлена и запущена."
  else
    info "Запуск пропущен. Позже выполните: sudo svnet --admin-start"
  fi

  echo
  admin_print_access
  echo
  echo "Первичная настройка:"
  echo "- Откройте http://svnet.local/setup после включения доступа из домашней сети."
  echo "- Setup token больше не нужен: первого администратора создайте прямо в браузере."
}

admin_status() {
