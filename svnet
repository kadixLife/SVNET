admin_reset_password() {
  require_root || return 1
  load_config

  local username password repeat
  read -r -p "Admin username: " username || return 1
  read -r -s -p "Новый пароль: " password || return 1
  echo
  read -r -s -p "Повторите пароль: " repeat || return 1
  echo

  if [[ "$password" != "$repeat" ]]; then
    fail "Пароли не совпадают."
    return 1
  fi

  if (( ${#password} < 12 )); then
    fail "Пароль должен быть не короче 12 символов."
    return 1
  fi

  run_admin_compose up -d postgres || return 1
  run_admin_compose build backend || return 1
  export SVNET_ADMIN_USER="$username"
  export SVNET_ADMIN_PASSWORD="$password"
  run_admin_compose run --rm -e SVNET_ADMIN_USER -e SVNET_ADMIN_PASSWORD backend node dist/adminCli.js reset-password
  local rc=$?
  unset SVNET_ADMIN_USER SVNET_ADMIN_PASSWORD
  return "$rc"
}

admin_reset_setup() {
  require_root || return 1
  load_config

  warn "Это developer recovery: существующие admin users будут удалены, и /setup снова станет доступен."
  warn "OpenVPN, MikroTik, firewall, .env и Docker volumes не будут удалены."
  confirm_word "Подтвердите сброс первичной настройки Admin Panel." "RESET_SETUP" || return 0

  run_admin_compose up -d postgres || return 1
  run_admin_compose build backend || return 1
  export SVNET_ADMIN_RESET_SETUP="RESET_SETUP"
  run_admin_compose run --rm -e SVNET_ADMIN_RESET_SETUP backend node dist/adminCli.js reset-setup
  local rc=$?
  unset SVNET_ADMIN_RESET_SETUP
  return "$rc"
}

