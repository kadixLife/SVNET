CLI="/usr/local/bin/svnet"
REPO_DIR="${SVNET_REPO_DIR:-/opt/svobodanet/repo}"
SVNET_GIT_URL="${SVNET_GIT_URL:-https://github.com/kadixLife/SVNET.git}"
ADMIN_DIR="/opt/svobodanet-admin"
ADMIN_ACCESS_HOST="svnet.local"
ADMIN_HTTP_PORT="80"
ADMIN_NGINX_AVAILABLE="/etc/nginx/sites-available/svnet-admin.conf"
ADMIN_NGINX_ENABLED="/etc/nginx/sites-enabled/svnet-admin.conf"
ADMIN_NGINX_DISABLED_DIR="/etc/nginx/svnet-disabled"
