}

generate_mikrotik_configs() {
  require_root || return 1
  load_config
  ensure_base_dirs
  ensure_default_lists || return 1

  if [[ "$(detect_mode)" == "Safe Upgrade Mode" ]]; then
    create_backup "pre-mikrotik-generate" || return 1
  fi

  if [[ ! -s "$CLIENTS/mikrotik.ovpn" ]]; then
    warn "Не найден $CLIENTS/mikrotik.ovpn. Install script сможет обновить правила, но новый import OpenVPN может потребовать ручной файл."
  elif [[ ! -s "$MIKROTIK/mikrotik.ovpn" ]]; then
    cp -a "$CLIENTS/mikrotik.ovpn" "$MIKROTIK/mikrotik.ovpn"
    ok "Скопирован $MIKROTIK/mikrotik.ovpn"
  fi

  local server_ip
  server_ip="$(get_server_ip)"

  status_openvpn || true
  echo

  atomic_generate "$MIKROTIK/svnet-mikrotik-install.rsc" gen_install_rsc "$server_ip" || return 1
  atomic_generate "$MIKROTIK/svnet-mikrotik-split-vpnfirst.rsc" gen_split_vpnfirst_rsc "$server_ip" || return 1
  atomic_generate "$MIKROTIK/svnet-mikrotik-fullvpn.rsc" gen_fullvpn_rsc "$server_ip" || return 1
  atomic_generate "$MIKROTIK/svnet-mikrotik-direct.rsc" gen_direct_rsc "$server_ip" || return 1
  atomic_generate "$MIKROTIK/svnet-mikrotik-scripts.rsc" gen_scripts_rsc "$server_ip" || return 1

  verify_generated_rsc || return 1
  show_mikrotik_install_command
}

check_mikrotik_connection() {
  load_config
  echo "Проверка MikroTik через VPN tunnel"
  echo

  if command_exists ping && ping -c 3 -W 2 "$CLIENT_IP"; then
    ok "MikroTik отвечает на ping: $CLIENT_IP"
  else
    warn "MikroTik не ответил на ping: $CLIENT_IP"
  fi

  if command_exists timeout; then
    if timeout 2 bash -c ":</dev/tcp/$CLIENT_IP/8728" >/dev/null 2>&1; then
      ok "RouterOS API port 8728 доступен"
    else
      warn "RouterOS API port 8728 недоступен или отключён. Это не критично."
    fi
  else
    warn "timeout не найден, API port 8728 не проверен."
  fi
}

generate_new_mikrotik_client() {
  require_root || return 1
  load_config

  warn "Генерация нового клиента меняет EasyRSA/OpenVPN client files."
  warn "Если текущий MikroTik уже подключается, обычно достаточно существующего $CLIENTS/mikrotik.ovpn."
  confirm_word "Продолжать только если нужен новый клиентский сертификат." "GENERATE" || {
    info "Генерация клиента отменена."
    return 0
  }

  create_backup "pre-client-generate" || return 1

  if [[ ! -x "$EASYRSA_DIR/easyrsa" ]]; then
    fail "Не найден $EASYRSA_DIR/easyrsa. Новый клиент не создан."
    return 1
  fi

  if [[ -f "$EASYRSA_DIR/pki/issued/${CLIENT_NAME}.crt" ]]; then
    warn "Сертификат $CLIENT_NAME уже существует. Я не буду перезаписывать его автоматически."
    return 1
  fi

  (cd "$EASYRSA_DIR" && EASYRSA_BATCH=1 ./easyrsa build-client-full "$CLIENT_NAME" nopass) || {
    fail "EasyRSA не смог создать клиента."
    return 1
  }

  mkdir -p "$CLIENTS" "$MIKROTIK"
  cat > "$CLIENTS/mikrotik.ovpn" <<OVPN
client
dev tun
proto $OVPN_PROTO
remote $(get_server_ip) $OVPN_PORT
nobind
persist-key
persist-tun
remote-cert-tls server
cipher AES-128-GCM
auth SHA256
auth-nocache
verb 3
route-nopull
pull-filter ignore "redirect-gateway"
tun-mtu 1500
mssfix 1360

<ca>
$(cat "$EASYRSA_DIR/pki/ca.crt")
</ca>
<cert>
$(cat "$EASYRSA_DIR/pki/issued/${CLIENT_NAME}.crt")
</cert>
<key>
$(cat "$EASYRSA_DIR/pki/private/${CLIENT_NAME}.key")
</key>
OVPN
  cp -a "$CLIENTS/mikrotik.ovpn" "$MIKROTIK/mikrotik.ovpn"
  chmod 0600 "$CLIENTS/mikrotik.ovpn" 2>/dev/null || true
  chmod 0644 "$MIKROTIK/mikrotik.ovpn" 2>/dev/null || true
  ok "Новый MikroTik client создан."
}

