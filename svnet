safe_remove_stage() {
  local stage="$1"
  case "$stage" in
    "$BACKUPS"/.staging-*) rm -rf -- "$stage" ;;
    *) warn "Временная директория backup не удалена: $stage" ;;
  esac
}

copy_path_to_stage() {
  local src="$1"
  local dst="$2"
  if [[ -e "$src" ]]; then
    mkdir -p "$(dirname "$dst")"
    cp -a "$src" "$dst"
  fi
}

cleanup_regular_backups() {
  local backups
  mapfile -t backups < <(find "$BACKUPS" -maxdepth 1 -type f -name 'svnet-backup-manual-*.tar.gz' 2>/dev/null | sort)
  local count="${#backups[@]}"
  local remove_count=$((count - 3))

  if (( remove_count <= 0 )); then
    return 0
  fi

  local i
  for ((i = 0; i < remove_count; i++)); do
    rm -f -- "${backups[$i]}"
  done
}

create_backup() {
  local kind="${1:-manual}"
  require_root || return 1
  load_config
  ensure_base_dirs

  local ts archive stage
  ts="$(date +%Y-%m-%d_%H-%M-%S)"
  archive="$BACKUPS/svnet-backup-${kind}-${ts}.tar.gz"
  stage="$BACKUPS/.staging-${kind}-${ts}-$$"

  mkdir -p "$stage"

  copy_path_to_stage "$BASE_DIR/config" "$stage/opt/svobodanet/config"
  copy_path_to_stage "$BASE_DIR/lists" "$stage/opt/svobodanet/lists"
  copy_path_to_stage "$BASE_DIR/output" "$stage/opt/svobodanet/output"
  copy_path_to_stage "$OVPN_SERVER_CONF" "$stage/etc/openvpn/server/svnet.conf"
  copy_path_to_stage "$HTTP_SERVICE_FILE" "$stage/etc/systemd/system/svnet-http.service"
  copy_path_to_stage "$CLI" "$stage/usr/local/bin/svnet"

  if command_exists iptables-save; then
    iptables-save > "$stage/iptables-save.rules" 2>/dev/null || true
  fi

  if tar -czf "$archive" -C "$stage" .; then
    safe_remove_stage "$stage"
    [[ "$kind" == "manual" ]] && cleanup_regular_backups
    ok "Backup создан: $archive"
    return 0
  fi

  safe_remove_stage "$stage"
  fail "Backup создать не удалось."
  return 1
}

show_backups() {
  require_root || return 1
  ensure_base_dirs

  local backups
  mapfile -t backups < <(find "$BACKUPS" -maxdepth 1 -type f -name 'svnet-backup-*.tar.gz' 2>/dev/null | sort -r)

  if (( ${#backups[@]} == 0 )); then
    warn "Backups не найдены."
    return 0
  fi

  local i prefix
  for ((i = 0; i < ${#backups[@]}; i++)); do
    if (( i == 0 )); then
      prefix="${GREEN}"
    else
      prefix=""
    fi
    printf '%s%2d) %s%s\n' "$prefix" "$((i + 1))" "${backups[$i]}" "$RESET"
  done
}

restore_file_if_present() {
  local src="$1"
  local dst="$2"
  if [[ -e "$src" ]]; then
    mkdir -p "$(dirname "$dst")"
    cp -a "$src" "$dst"
  fi
}

restore_dir_if_present() {
  local src="$1"
  local dst="$2"
  if [[ -d "$src" ]]; then
    mkdir -p "$dst"
    cp -a "$src/." "$dst/"
  fi
}

restore_backup() {
  require_root || return 1
  ensure_base_dirs

  local backups
  mapfile -t backups < <(find "$BACKUPS" -maxdepth 1 -type f -name 'svnet-backup-*.tar.gz' 2>/dev/null | sort -r)
  if (( ${#backups[@]} == 0 )); then
    warn "Backups не найдены."
    return 0
  fi

  show_backups
  echo

  local choice archive stage
  read -r -p "Введите номер backup для восстановления: " choice || return 1
  if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#backups[@]} )); then
    fail "Неверный номер backup."
    return 1
  fi

  archive="${backups[$((choice - 1))]}"

  warn "Restore может перезаписать config/lists/output/OpenVPN/systemd/CLI."
  confirm_word "Перед restore будет создан pre-restore backup." "RESTORE" || {
    info "Restore отменён."
    return 0
  }

  create_backup "pre-restore" || return 1

  stage="$BACKUPS/.staging-restore-$(date +%Y-%m-%d_%H-%M-%S)-$$"
  mkdir -p "$stage"

  if ! tar -xzf "$archive" -C "$stage"; then
    safe_remove_stage "$stage"
    fail "Не удалось распаковать backup."
    return 1
  fi

  restore_dir_if_present "$stage/opt/svobodanet/config" "$BASE_DIR/config"
  restore_dir_if_present "$stage/opt/svobodanet/lists" "$BASE_DIR/lists"
  restore_dir_if_present "$stage/opt/svobodanet/output" "$BASE_DIR/output"
  restore_file_if_present "$stage/etc/openvpn/server/svnet.conf" "$OVPN_SERVER_CONF"
  restore_file_if_present "$stage/etc/systemd/system/svnet-http.service" "$HTTP_SERVICE_FILE"
  restore_file_if_present "$stage/usr/local/bin/svnet" "$CLI"

  if [[ -f "$stage/iptables-save.rules" ]]; then
    if confirm "Восстановить iptables из backup сейчас?"; then
      if command_exists iptables-restore; then
        iptables-restore < "$stage/iptables-save.rules" && ok "iptables восстановлены."
      else
        warn "iptables-restore не найден."
      fi
    else
      info "iptables сохранены в backup, но не применялись."
    fi
  fi

  safe_remove_stage "$stage"

  command_exists systemctl && systemctl daemon-reload >/dev/null 2>&1 || true
  ok "Restore завершён."
  status_openvpn
}

clean_old_backups() {
  require_root || return 1
  ensure_base_dirs
  cleanup_regular_backups
  ok "Старые обычные backups очищены. pre-* backups не удалялись."
}

check_http_url() {
  local url="$1"
  local code
  if ! command_exists curl; then
    warn "curl не найден: $url не проверен."
    return 1
  fi
  code="$(curl -fsS -o /dev/null -w '%{http_code}' -I "$url" 2>/dev/null || true)"
  [[ "$code" == "200" ]]
}

http_status_code() {
  local url="$1"
  local code
  if ! command_exists curl; then
    printf '%s\n' "curl-missing"
    return 0
  fi
  code="$(curl -sS -o /dev/null -w '%{http_code}' -I --max-time 5 "$url" 2>/dev/null || true)"
  printf '%s\n' "${code:-000}"
}

http_publish_urls() {
  printf '%s\n' \
    "/clients/mikrotik.ovpn" \
    "/mikrotik/svnet-mikrotik-install.rsc" \
    "/mikrotik/svnet-mikrotik-split-vpnfirst.rsc"
}

http_port_ss_lines() {
  command_exists ss || return 0
  ss -H -ltnp 2>/dev/null | grep -E "(:|\])${HTTP_PORT}\b" || true
}

http_port_wildcard_listener_lines() {
  http_port_ss_lines | grep -E "(^|[[:space:]])(0\.0\.0\.0:${HTTP_PORT}|\*:${HTTP_PORT}|\[::\]:${HTTP_PORT}|:::${HTTP_PORT})([[:space:]]|$)" || true
}

http_port_public_listener_lines() {
  local server_ip lines
  server_ip="$(get_server_ip)"
  lines="$(http_port_ss_lines)"
  {
    http_port_wildcard_listener_lines
    if [[ -n "$server_ip" && "$server_ip" != "SERVER_IP" && "$server_ip" != "$VPN_SERVER_IP" ]]; then
      printf '%s\n' "$lines" | grep -F "${server_ip}:${HTTP_PORT}" || true
    fi
  } | sort -u
}

http_port_pids() {
  http_port_ss_lines | grep -oE 'pid=[0-9]+' 2>/dev/null | cut -d= -f2 | sort -u
}

http_port_is_listening() {
  [[ -n "$(http_port_ss_lines)" ]]
}

pid_systemd_unit() {
  local pid="$1" unit

  if [[ -r "/proc/$pid/cgroup" ]]; then
    unit="$(grep -oE '[A-Za-z0-9_.@-]+\.service' "/proc/$pid/cgroup" 2>/dev/null | tail -n1 || true)"
    if [[ -n "$unit" ]]; then
      printf '%s\n' "$unit"
      return 0
    fi
  fi

  if command_exists systemctl; then
    unit="$(systemctl status "$pid" --no-pager 2>/dev/null | grep -m1 -oE '[A-Za-z0-9_.@-]+\.service' || true)"
    if [[ -n "$unit" ]]; then
      printf '%s\n' "$unit"
      return 0
    fi
  fi

  return 1
}

http_public_ip_code() {
  local server_ip code
  server_ip="$(get_server_ip)"
  if [[ -z "$server_ip" || "$server_ip" == "SERVER_IP" || "$server_ip" == "$VPN_SERVER_IP" ]]; then
    printf '%s\n' "skipped"
    return 0
  fi

  if ! command_exists curl; then
    printf '%s\n' "curl-missing"
    return 0
  fi

  code="$(curl -sS -o /dev/null -w '%{http_code}' -I --connect-timeout 3 --max-time 5 "http://${server_ip}:${HTTP_PORT}" 2>/dev/null || true)"
  printf '%s\n' "${code:-000}"
}

print_http_listener_status() {
  local service_active="${1:-unknown}"
  echo "HTTP port $HTTP_PORT listener"

  if ! command_exists ss; then
    warn "ss не найден: порт $HTTP_PORT не проверен."
    echo
    return 0
  fi

  local lines pids pid cwd unit
  lines="$(http_port_ss_lines)"
  if [[ -z "$lines" ]]; then
    if [[ "$service_active" == "yes" ]]; then
      fail "$HTTP_SERVICE active, but port $HTTP_PORT is not listening"
    else
      ok "port $HTTP_PORT: not listening"
    fi
    echo
    return 0
  fi

  ok "port $HTTP_PORT: listening"
  echo "$lines"
  echo "Served directory: $OUTPUT"
  mapfile -t pids < <(printf '%s\n' "$lines" | grep -oE 'pid=[0-9]+' 2>/dev/null | cut -d= -f2 | sort -u)

  if (( ${#pids[@]} == 0 )); then
    warn "PID процесса на $HTTP_PORT не определён."
    echo
    return 0
  fi

  for pid in "${pids[@]}"; do
    cwd="$(readlink -f "/proc/$pid/cwd" 2>/dev/null || true)"
    unit="$(pid_systemd_unit "$pid" 2>/dev/null || true)"
    echo "PID: $pid"
    if [[ -n "$unit" ]]; then
      echo "Systemd unit: $unit"
    else
      echo "Systemd unit: unknown"
    fi
    if [[ -n "$cwd" ]]; then
      echo "CWD: $cwd"
    else
      echo "CWD: недоступно"
    fi
  done
  echo
}

kill_http_port_listeners() {
  local pids pid
  mapfile -t pids < <(http_port_pids)
  if (( ${#pids[@]} == 0 )); then
    return 0
  fi

  for pid in "${pids[@]}"; do
    warn "Останавливаю процесс на порту $HTTP_PORT: PID $pid"
    kill "$pid" 2>/dev/null || true
  done

  sleep 1

  for pid in "${pids[@]}"; do
    if kill -0 "$pid" 2>/dev/null; then
      warn "PID $pid ещё жив, выполняю kill -9."
      kill -9 "$pid" 2>/dev/null || true
    fi
  done
}

known_legacy_service_candidates() {
  {
    printf '%s\n' "$LEGACY_KADI_HTTP_SERVICE"
    if command_exists systemctl; then
      systemctl list-unit-files --no-legend 'kadi*.service' 'kadi-*.service' 2>/dev/null | awk '{print $1}'
      systemctl list-units --all --no-legend 'kadi*.service' 'kadi-*.service' 2>/dev/null | awk '{print $1}'
    fi
  } | sort -u
}

systemd_unit_known() {
  local unit="$1"
  command_exists systemctl || return 1
  systemctl list-unit-files --no-legend "$unit" 2>/dev/null | awk '{print $1}' | grep -Fxq "$unit" && return 0
  systemctl list-units --all --no-legend "$unit" 2>/dev/null | awk '{print $1}' | grep -Fxq "$unit"
}

is_known_legacy_http_unit() {
  local unit="$1"
  [[ "$unit" == "$LEGACY_KADI_HTTP_SERVICE" ]]
}

disable_legacy_service_unit() {
  local unit="$1"
  command_exists systemctl || {
    warn "systemctl не найден, не могу отключить $unit."
    return 1
  }

  warn "Найден старый KADI service: $unit"
  confirm "Отключить старый KADI HTTP service $unit?" || return 1

  systemctl stop "$unit" >/dev/null 2>&1 || true
  systemctl disable "$unit" >/dev/null 2>&1 || true
  systemctl mask "$unit" >/dev/null 2>&1 || true
  systemctl daemon-reload >/dev/null 2>&1 || true
  ok "Legacy service disabled and masked: $unit"
}

cleanup_http_port_legacy_units() {
  local pids pid unit changed=0 declined=0
  mapfile -t pids < <(http_port_pids)

  for pid in "${pids[@]}"; do
    unit="$(pid_systemd_unit "$pid" 2>/dev/null || true)"
    [[ -n "$unit" ]] || continue
    if is_known_legacy_http_unit "$unit"; then
      if disable_legacy_service_unit "$unit"; then
        changed=1
      else
        declined=1
      fi
    fi
  done

  if [[ "$changed" == "1" ]]; then
    sleep 1
  fi

  [[ "$declined" == "0" ]]
}

verify_http_publish_public_closed() {
  local code public_lines problems=0

  if http_port_is_listening; then
    warn "ss показывает listener на $HTTP_PORT:"
    http_port_ss_lines
  else
    ok "ss: port $HTTP_PORT not listening"
  fi

  public_lines="$(http_port_public_listener_lines)"
  if [[ -n "$public_lines" ]]; then
    fail "HTTP publish ${HTTP_PORT}: public/wildcard listener найден"
    printf '%s\n' "$public_lines"
    ((problems++))
  else
    ok "HTTP publish ${HTTP_PORT}: no public/wildcard listener"
  fi

  code="$(http_public_ip_code)"
  case "$code" in
    000) ok "curl public IP:${HTTP_PORT}: refused/timeout" ;;
    skipped) warn "curl public IP:${HTTP_PORT}: skipped, public IP не определён" ;;
    curl-missing) warn "curl public IP:${HTTP_PORT}: curl не найден" ;;
    *) fail "curl public IP:${HTTP_PORT}: HTTP $code"; ((problems++)) ;;
  esac

  return "$problems"
}

cleanup_legacy_services() {
  require_root || return 1
  load_config

  local services unit found=0
  echo "Cleanup legacy KADI services"
  echo
  mapfile -t services < <(known_legacy_service_candidates)

  for unit in "${services[@]}"; do
    [[ -n "$unit" ]] || continue
    systemd_unit_known "$unit" || continue
    found=1
    disable_legacy_service_unit "$unit" || true
  done

  if [[ "$found" == "0" ]]; then
    ok "Known legacy KADI services не найдены."
  fi

  echo
  verify_http_publish_public_closed || return 1
}

write_http_publish_service() {
  load_config
  mkdir -p "$(dirname "$HTTP_SERVICE_FILE")"
  cat > "$HTTP_SERVICE_FILE" <<HTTP
[Unit]
Description=SvobodaNET config HTTP server
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 -m http.server $HTTP_PORT --bind 0.0.0.0 --directory $OUTPUT
Restart=no

[Install]
WantedBy=multi-user.target
HTTP
}

verify_http_publish_urls() {
  load_config
  local mode="${1:-verbose}"
  local path code problems=0
  for path in $(http_publish_urls); do
    code="$(http_status_code "http://127.0.0.1:${HTTP_PORT}${path}")"
    if [[ "$code" == "200" ]]; then
      if [[ "$mode" != "quiet" ]]; then
        ok "HTTP $path: 200 OK"
      fi
    else
      if [[ "$mode" != "quiet" ]]; then
        warn "HTTP $path: $code"
      fi
      ((problems++))
    fi
  done
  return "$problems"
}

wait_for_http_publish_urls() {
  load_config
  local attempt
  info "Ждём запуск HTTP publish..."
  for attempt in {1..10}; do
    info "Проверка URL, попытка $attempt/10..."
    if verify_http_publish_urls quiet; then
      return 0
    fi
    sleep 1
  done

  fail "HTTP publish не вернул 200 OK для всех обязательных URL за 10 попыток."
  verify_http_publish_urls || true
  return 1
}

status_openvpn() {
  load_config
  local problems=0
  local server_ip
  server_ip="$(get_server_ip)"

  echo "Статус OpenVPN и публикации"
  echo

  if command_exists systemctl && systemctl is-active --quiet "$OVPN_SERVICE"; then
    ok "OpenVPN service: active"
  else
    fail "OpenVPN service: не active"
    ((problems++))
  fi

  if command_exists ip && ip -4 -o addr show dev "$OVPN_IF" >/dev/null 2>&1; then
    if ip -4 -o addr show dev "$OVPN_IF" 2>/dev/null | grep -q " ${VPN_SERVER_IP}/"; then
      ok "$OVPN_IF: $VPN_SERVER_IP"
    else
      warn "$OVPN_IF найден, но IP $VPN_SERVER_IP не подтверждён"
      ip -4 -o addr show dev "$OVPN_IF" 2>/dev/null || true
    fi
  else
    fail "$OVPN_IF: интерфейс не найден"
    ((problems++))
  fi

  if command_exists ss && ss -lunp 2>/dev/null | grep -Eq ":${OVPN_PORT}\b.*openvpn|:${OVPN_PORT}\b"; then
    ok "UDP port $OVPN_PORT: listening"
  else
    fail "UDP port $OVPN_PORT: не найден слушающий socket"
    ((problems++))
  fi

  if command_exists sysctl && [[ "$(sysctl -n net.ipv4.ip_forward 2>/dev/null || true)" == "1" ]]; then
    ok "net.ipv4.ip_forward=1"
  else
    warn "net.ipv4.ip_forward не равен 1 или sysctl недоступен"
  fi

  if command_exists iptables; then
    iptables -C INPUT -i "$OVPN_IF" -j ACCEPT 2>/dev/null && ok "iptables INPUT $OVPN_IF: есть" || warn "iptables INPUT $OVPN_IF: не найдено"
    iptables -C INPUT -p udp --dport "$OVPN_PORT" -j ACCEPT 2>/dev/null && ok "iptables INPUT udp/$OVPN_PORT: есть" || warn "iptables INPUT udp/$OVPN_PORT: не найдено"
    iptables -C FORWARD -i "$OVPN_IF" -o "$WAN_IF" -j ACCEPT 2>/dev/null && ok "iptables FORWARD $OVPN_IF -> $WAN_IF: есть" || warn "iptables FORWARD $OVPN_IF -> $WAN_IF: не найдено"
    iptables -C FORWARD -i "$WAN_IF" -o "$OVPN_IF" -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT 2>/dev/null \
      && ok "iptables FORWARD $WAN_IF -> $OVPN_IF RELATED,ESTABLISHED: есть" \
      || warn "iptables FORWARD $WAN_IF -> $OVPN_IF RELATED,ESTABLISHED: не найдено"
    iptables -t nat -C POSTROUTING -s "$VPN_CIDR" -o "$WAN_IF" -j MASQUERADE 2>/dev/null \
      && ok "NAT $VPN_CIDR -> $WAN_IF: есть" \
      || warn "NAT $VPN_CIDR -> $WAN_IF: не найдено"
  else
    warn "iptables не найден."
  fi

  if command_exists systemctl && systemctl is-active --quiet "$HTTP_SERVICE"; then
    ok "HTTP publish service: active"
    if check_http_url "http://127.0.0.1:${HTTP_PORT}/clients/mikrotik.ovpn"; then
      ok "HTTP clients/mikrotik.ovpn: 200 OK"
    else
      warn "HTTP clients/mikrotik.ovpn: нет 200 OK"
    fi

    if check_http_url "http://127.0.0.1:${HTTP_PORT}/mikrotik/svnet-mikrotik-split-vpnfirst.rsc"; then
      ok "HTTP split-vpnfirst.rsc: 200 OK"
    else
      warn "HTTP split-vpnfirst.rsc: нет 200 OK"
    fi
  else
    ok "HTTP publish: offline secure mode"
  fi

  local required=(
    "$CLIENTS/mikrotik.ovpn"
    "$MIKROTIK/svnet-mikrotik-split-vpnfirst.rsc"
    "$MIKROTIK/svnet-mikrotik-fullvpn.rsc"
    "$MIKROTIK/svnet-mikrotik-direct.rsc"
    "$MIKROTIK/svnet-mikrotik-scripts.rsc"
  )
  local f
  for f in "${required[@]}"; do
    if [[ -s "$f" ]]; then
      ok "Output file: $f"
    else
      warn "Output file отсутствует или пустой: $f"
    fi
  done

  if [[ -d "$ADMIN_DIR" ]]; then
    ok "GUI Admin Panel: подготовлена директория $ADMIN_DIR"
  else
    warn "GUI Admin Panel: not installed"
  fi

  echo
  info "Публичная команда для MikroTik использует: http://$server_ip:$HTTP_PORT"
  return "$problems"
}

publish_on() {
  require_root || return 1
  load_config

  if ! command_exists systemctl; then
    fail "systemctl не найден."
    return 1
  fi

  systemctl stop "$HTTP_SERVICE" >/dev/null 2>&1 || true
  kill_http_port_listeners
  write_http_publish_service
  systemctl daemon-reload
  systemctl disable "$HTTP_SERVICE" >/dev/null 2>&1 || true
  if ! systemctl start "$HTTP_SERVICE"; then
    fail "Не удалось запустить $HTTP_SERVICE."
    return 1
  fi
  ok "HTTP publish включён временно."
  wait_for_http_publish_urls || return 1
  publish_status strict
}

publish_off() {
  require_root || return 1
  load_config

  if ! command_exists systemctl; then
    fail "systemctl не найден."
    return 1
  fi

  systemctl stop "$HTTP_SERVICE" >/dev/null 2>&1 || true
  systemctl disable "$HTTP_SERVICE" >/dev/null 2>&1 || true
  if http_port_is_listening; then
    cleanup_http_port_legacy_units || true
  fi
  kill_http_port_listeners
  if http_port_is_listening; then
    fail "Порт $HTTP_PORT всё ещё слушается."
    print_http_listener_status no
    return 1
  fi
  ok "HTTP publish отключён. OpenVPN не тронут."
  verify_http_publish_public_closed || true
  publish_status
}

publish_status() {
  load_config
  local strict="${1:-}"
  local server_ip active listening curl_result
  server_ip="$(get_server_ip)"
  active="no"
  listening="no"
  curl_result=0

  echo "HTTP publish status"
  echo

  if command_exists systemctl && systemctl is-active --quiet "$HTTP_SERVICE"; then
    active="yes"
    ok "$HTTP_SERVICE: active"
  fi

  if http_port_is_listening; then
    listening="yes"
  fi

  if [[ "$active" == "no" && "$listening" == "no" ]]; then
    ok "HTTP publish: offline secure mode"
  elif [[ "$active" == "no" ]]; then
    warn "$HTTP_SERVICE: inactive"
  fi

  if [[ "$active" == "no" && "$listening" == "yes" ]]; then
    warn "Найден посторонний HTTP process на $HTTP_PORT"
  fi
  print_http_listener_status "$active"

  echo
  echo "URL публикации:"
  echo "URL доступны только когда $HTTP_SERVICE active."
  echo "http://$server_ip:$HTTP_PORT/clients/mikrotik.ovpn"
  echo "http://$server_ip:$HTTP_PORT/mikrotik/svnet-mikrotik-install.rsc"
  echo "http://$server_ip:$HTTP_PORT/mikrotik/svnet-mikrotik-split-vpnfirst.rsc"
  echo

  if [[ "$active" == "no" && "$listening" == "no" ]]; then
    ok "URL конфигов недоступны, публикация отключена"
  else
    verify_http_publish_urls || curl_result=$?
  fi

  if [[ "$active" != "yes" && "$listening" == "yes" ]]; then
    info "Публикация конфигов отключена. Для установки MikroTik включите: sudo svnet --publish-on"
  fi

  [[ "$strict" == "strict" ]] && return "$curl_result"
  return 0
}

restart_openvpn() {
  require_root || return 1
  load_config

  warn "Будет создан backup и перезапущен $OVPN_SERVICE."
  confirm "Продолжить?" || {
    info "Перезапуск отменён."
    return 0
  }

  if [[ "$(detect_mode)" == "Safe Upgrade Mode" ]]; then
    create_backup "pre-openvpn-restart" || return 1
  fi

  if systemctl restart "$OVPN_SERVICE"; then
    sleep 2
    status_openvpn
  else
    fail "OpenVPN не перезапустился. Последние записи журнала:"
    journalctl -u "$OVPN_SERVICE" -n 80 --no-pager || true
    return 1
  fi
}

ensure_http_publish_service() {
  require_root || return 1
  load_config

  local desired_exec="/usr/bin/python3 -m http.server $HTTP_PORT --bind 0.0.0.0 --directory $OUTPUT"

  if [[ -f "$HTTP_SERVICE_FILE" ]] && grep -Fq -- "$desired_exec" "$HTTP_SERVICE_FILE" && grep -Fq "Restart=no" "$HTTP_SERVICE_FILE"; then
    ok "HTTP publish service уже использует --directory $OUTPUT"
    return 0
  fi

  warn "HTTP publish service отличается от безопасного шаблона, перезаписываю unit."
  write_http_publish_service
  systemctl daemon-reload
  ok "HTTP publish service обновлён."
}

clean_file() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  sed 's/\r$//' "$file" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | grep -vE '^($|#)' | sort -u
}

validate_domain() {
  local value="$1"
  [[ "$value" =~ ^([A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?\.)+[A-Za-z]{2,}$ ]]
}

validate_ip_or_cidr() {
  local value="$1"
  python3 - "$value" <<'PY' >/dev/null 2>&1
import ipaddress
import sys
ipaddress.ip_network(sys.argv[1], strict=False)
PY
}

normalize_value() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s\n' "$value"
}

add_unique_line() {
  local file="$1"
  local value="$2"
  mkdir -p "$(dirname "$file")"
  touch "$file"
  if grep -qxF "$value" "$file"; then
    warn "Уже есть: $value"
    return 0
  fi
  printf '%s\n' "$value" >> "$file"
  sort -u "$file" -o "$file"
  ok "Добавлено: $value"
}

remove_line() {
  local file="$1"
  local value="$2"
  if [[ ! -f "$file" ]]; then
    warn "Список пока пуст."
    return 0
  fi
  if ! grep -qxF "$value" "$file"; then
    warn "Запись не найдена: $value"
    return 0
  fi
  grep -vxF "$value" "$file" > "${file}.tmp.$$"
  mv -f "${file}.tmp.$$" "$file"
  ok "Удалено: $value"
}

dedupe_list() {
  local file="$1"
  [[ -f "$file" ]] || : > "$file"
  clean_file "$file" > "${file}.tmp.$$"
  mv -f "${file}.tmp.$$" "$file"
  ok "Дубли очищены."
}

validate_list_file() {
  local file="$1"
  local type="$2"
  local invalid=0
  local duplicates=0
  local line

  if [[ ! -f "$file" ]]; then
    warn "Список не найден: $file"
    return 0
  fi

  while IFS= read -r line; do
    line="$(normalize_value "$line")"
    [[ -z "$line" || "$line" =~ ^# ]] && continue
    if [[ "$type" == "domain" ]]; then
      validate_domain "$line" || {
        fail "Неверный домен: $line"
        ((invalid++))
      }
    else
      validate_ip_or_cidr "$line" || {
        fail "Неверный IP/подсеть: $line"
        ((invalid++))
      }
    fi
  done < "$file"

  duplicates="$(sort "$file" 2>/dev/null | uniq -d | grep -vcE '^($|#)' || true)"
  if (( duplicates > 0 )); then
    warn "Найдены дубли: $duplicates"
  fi

  if (( invalid == 0 && duplicates == 0 )); then
    ok "Ошибки не найдены."
  else
    warn "Проверьте список перед генерацией MikroTik правил."
  fi

  return 0
}

list_file_by_key() {
  case "$1" in
    direct_domains) printf '%s\n' "$LISTS/direct-domains.txt" ;;
    vpn_domains) printf '%s\n' "$LISTS/vpn-domains.txt" ;;
    direct_ip) printf '%s\n' "$LISTS/direct-ip.txt" ;;
    vpn_ip) printf '%s\n' "$LISTS/vpn-ip.txt" ;;
    local_bypass) printf '%s\n' "$LISTS/local-bypass.txt" ;;
    *) return 1 ;;
  esac
}

list_title_by_key() {
  case "$1" in
    direct_domains) printf '%s\n' "Российские сайты напрямую без VPN" ;;
    vpn_domains) printf '%s\n' "Заблокированные сайты через VPN" ;;
    direct_ip) printf '%s\n' "Российские IP/подсети напрямую без VPN" ;;
    vpn_ip) printf '%s\n' "IP/подсети принудительно через VPN" ;;
    local_bypass) printf '%s\n' "Локальная сеть без VPN" ;;
    *) return 1 ;;
  esac
}

list_type_by_key() {
  case "$1" in
    direct_domains|vpn_domains) printf '%s\n' "domain" ;;
    direct_ip|vpn_ip|local_bypass) printf '%s\n' "ip" ;;
    *) return 1 ;;
  esac
}

prompt_rebuild_after_list_change() {
  if confirm "Списки изменены. Пересобрать правила для MikroTik сейчас?"; then
    generate_mikrotik_configs
  fi
}

show_add_hint() {
  local type="$1"
  if [[ "$type" == "domain" ]]; then
    cat <<'TEXT'
Введите домен без https:// и без слэшей.
Правильно: yandex.ru
Неправильно: https://yandex.ru/
TEXT
  else
    cat <<'TEXT'
Введите IP или подсеть.
Правильно: 192.168.50.0/24 или 8.8.8.8
Неправильно: http://8.8.8.8
TEXT
  fi
}

manage_one_list() {
  require_root || return 1
  load_config
  ensure_default_lists || return 1

  local key="$1"
  local file title type choice value
  file="$(list_file_by_key "$key")"
  title="$(list_title_by_key "$key")"
  type="$(list_type_by_key "$key")"

  while true; do
    header
    menu_title "$title"
    menu_item "1" "Показать список" "Посмотреть текущие домены или IP, ничего не меняя."
    menu_item "2" "Добавить запись" "Добавить один домен, IP или подсеть в этот список."
    menu_item "3" "Удалить запись" "Убрать одну ненужную запись из списка."
    menu_item "4" "Добавить сразу много строк" "Вставить несколько доменов или IP подряд."
    menu_item "5" "Очистить дубли" "Удалить повторяющиеся строки из списка."
    menu_item "6" "Проверить ошибки" "Найти неправильные домены, IP, подсети и повторы."
    menu_item "7" "Сохранить и пересобрать правила" "Создать новые MikroTik-файлы с учётом изменений."
    menu_item "0" "Назад" "Вернуться в предыдущее меню."
    echo
    read -r -p "Выберите пункт: " choice || return 0

    case "$choice" in
      1)
        echo
        clean_file "$file" || true
        pause
        ;;
      2)
        show_add_hint "$type"
        read -r -p "> " value || true
        value="$(normalize_value "$value")"
        if [[ "$type" == "domain" ]]; then
          if ! validate_domain "$value"; then
            fail "Неверный домен."
            pause
            continue
          fi
        else
          if ! validate_ip_or_cidr "$value"; then
            fail "Неверный IP или подсеть."
            pause
            continue
          fi
        fi
        create_backup "pre-list-change" || { pause; continue; }
        add_unique_line "$file" "$value"
        prompt_rebuild_after_list_change
        pause
        ;;
      3)
        read -r -p "Введите запись для удаления: " value || true
        value="$(normalize_value "$value")"
        create_backup "pre-list-change" || { pause; continue; }
        remove_line "$file" "$value"
        prompt_rebuild_after_list_change
        pause
        ;;
      4)
        echo "Введите строки. Пустая строка завершает ввод."
        create_backup "pre-list-change" || { pause; continue; }
        while true; do
          read -r -p "> " value || break
          value="$(normalize_value "$value")"
          [[ -z "$value" ]] && break
          if [[ "$type" == "domain" ]]; then
            validate_domain "$value" && add_unique_line "$file" "$value" || warn "Пропущен неверный домен: $value"
          else
            validate_ip_or_cidr "$value" && add_unique_line "$file" "$value" || warn "Пропущен неверный IP/подсеть: $value"
          fi
        done
        prompt_rebuild_after_list_change
        pause
        ;;
      5)
        create_backup "pre-list-change" || { pause; continue; }
        dedupe_list "$file"
        prompt_rebuild_after_list_change
        pause
        ;;
      6)
        validate_list_file "$file" "$type"
        pause
        ;;
      7)
        validate_list_file "$file" "$type"
        generate_mikrotik_configs
        pause
        ;;
      0)
        return 0
        ;;
      *)
        warn "Неверный пункт."
        sleep 1
        ;;
    esac
  done
}

emit_ip_list() {
  local file="$1"
  local list_name="$2"
  local label="$3"
  local ip
  clean_file "$file" | while IFS= read -r ip; do
    [[ -z "$ip" ]] && continue
    printf '/ip firewall address-list add list=%s address=%s comment="SVNET %s %s"\n' "$list_name" "$ip" "$label" "$ip"
  done
}

emit_dns_rules() {
  local file="$1"
  local list_name="$2"
  local label="$3"
  local domain
  clean_file "$file" | while IFS= read -r domain; do
    [[ -z "$domain" ]] && continue
    printf '/ip dns static add name="%s" type=FWD forward-to=1.1.1.1 match-subdomain=yes address-list=%s comment="SVNET-DOMAIN-%s %s"\n' "$domain" "$list_name" "$label" "$domain"
  done
}

emit_rsc_header() {
  local title="$1"
  local server_ip="$2"
  cat <<RSC
# ============================================================
# СвободаNET Manager v$VERSION
# $title
# Generated: $(date -u +"%Y-%m-%d %H:%M:%S UTC")
# Server: $server_ip
# VPN interface: $MIKROTIK_OVPN_IF
# LAN: $MIKROTIK_LAN
# ============================================================

RSC
}

emit_rsc_ovpn_guard() {
  cat <<RSC
:if ([:len [/interface ovpn-client find name="$MIKROTIK_OVPN_IF"]] = 0) do={
    :error "SVNET: OpenVPN interface $MIKROTIK_OVPN_IF not found. Import mikrotik.ovpn first."
}

RSC
}

emit_rsc_install_ovpn_block() {
  local server_ip="$1"
  cat <<RSC
:local svnetBase "http://$server_ip:$HTTP_PORT"
:local svnetOvpnFile "mikrotik.ovpn"

:if ([:len [/interface ovpn-client find name="$MIKROTIK_OVPN_IF"]] = 0) do={
    :log warning "SVNET: OpenVPN client not found, trying to fetch and import mikrotik.ovpn"
    :do {
        /tool fetch url=(\$svnetBase . "/clients/mikrotik.ovpn") dst-path=\$svnetOvpnFile keep-result=yes
    } on-error={
        :log warning "SVNET: cannot fetch mikrotik.ovpn"
    }
    :do {
        /interface ovpn-client import-ovpn-configuration ovpn-configuration=\$svnetOvpnFile ovpn-user=ovpnuser skip-cert-import=no
    } on-error={
        :log warning "SVNET: automatic OpenVPN import failed. Import mikrotik.ovpn manually, then run this script again."
    }
}

:if ([:len [/interface ovpn-client find name="$MIKROTIK_OVPN_IF"]] = 0) do={
    :error "SVNET: OpenVPN interface $MIKROTIK_OVPN_IF is still missing"
}

/interface ovpn-client
set [find name="$MIKROTIK_OVPN_IF"] connect-to=$server_ip protocol=$OVPN_PROTO route-nopull=yes use-peer-dns=no disabled=no

RSC
}

emit_rsc_base_network() {
  cat <<RSC
/routing table
:if ([:len [find name="to-vpn"]] = 0) do={ add name=to-vpn fib }

/ip route
remove [find comment="SVNET VPN default route"]
add dst-address=0.0.0.0/0 gateway=$MIKROTIK_OVPN_IF routing-table=to-vpn distance=1 comment="SVNET VPN default route"

/ip firewall nat
remove [find comment="SVNET NAT LAN to OpenVPN"]
remove [find comment="SVNET DIRECT WAN NAT"]
add chain=srcnat out-interface=$MIKROTIK_WAN action=masquerade comment="SVNET DIRECT WAN NAT"
add chain=srcnat src-address=$MIKROTIK_LAN out-interface=$MIKROTIK_OVPN_IF action=masquerade comment="SVNET NAT LAN to OpenVPN"

RSC
}

emit_rsc_lists_and_dns() {
  local server_ip="$1"
  cat <<RSC
/ip firewall address-list
remove [find list="SVNET_DIRECT_IP" dynamic=no comment~"SVNET"]
remove [find list="SVNET_FORCE_VPN_IP" dynamic=no comment~"SVNET"]
remove [find list="SVNET_LOCAL_BYPASS" dynamic=no comment~"SVNET"]
add list=SVNET_DIRECT_IP address=$server_ip comment="SVNET DIRECT server endpoint"

RSC

  emit_ip_list "$LISTS/direct-ip.txt" "SVNET_DIRECT_IP" "DIRECT-IP"
  emit_ip_list "$LISTS/vpn-ip.txt" "SVNET_FORCE_VPN_IP" "VPN-IP"
  emit_ip_list "$LISTS/local-bypass.txt" "SVNET_LOCAL_BYPASS" "LOCAL"

  cat <<RSC

/ip dns static
remove [find comment~"SVNET-DOMAIN-DIRECT"]
remove [find comment~"SVNET-DOMAIN-VPN"]
RSC

  emit_dns_rules "$LISTS/direct-domains.txt" "SVNET_DIRECT_IP" "DIRECT"
  emit_dns_rules "$LISTS/vpn-domains.txt" "SVNET_FORCE_VPN_IP" "VPN"

  cat <<RSC

/ip dns static remove [find name="$ADMIN_ACCESS_HOST"]
/ip dns static add name="$ADMIN_ACCESS_HOST" address=$VPN_SERVER_IP comment="SVNET Admin Panel"
:log info "SVNET Admin DNS configured: $ADMIN_ACCESS_HOST -> $VPN_SERVER_IP"
:put "SVNET Admin Panel: http://$ADMIN_ACCESS_HOST"
RSC
}

emit_rsc_dns_redirect() {
  cat <<RSC

/ip firewall nat
remove [find comment="SVNET DNS redirect UDP"]
remove [find comment="SVNET DNS redirect TCP"]
add chain=dstnat src-address=$MIKROTIK_LAN protocol=udp dst-port=53 action=redirect to-ports=53 comment="SVNET DNS redirect UDP"
add chain=dstnat src-address=$MIKROTIK_LAN protocol=tcp dst-port=53 action=redirect to-ports=53 comment="SVNET DNS redirect TCP"

RSC
}

emit_rsc_split_vpnfirst_mangle() {
  cat <<RSC
/ip firewall mangle
remove [find comment~"SVNET-PBR"]
remove [find comment~"SVNET MSS"]
add chain=prerouting src-address=$MIKROTIK_LAN dst-address-list=SVNET_LOCAL_BYPASS action=accept comment="SVNET-PBR LOCAL BYPASS"
add chain=prerouting src-address=$MIKROTIK_LAN dst-address-list=SVNET_DIRECT_IP action=accept comment="SVNET-PBR SPLIT DIRECT BYPASS"
add chain=prerouting src-address=$MIKROTIK_LAN dst-address-list=SVNET_FORCE_VPN_IP action=mark-routing new-routing-mark=to-vpn passthrough=no comment="SVNET-PBR SPLIT FORCE VPN"
add chain=prerouting src-address=$MIKROTIK_LAN dst-address-type=!local action=mark-routing new-routing-mark=to-vpn passthrough=no comment="SVNET-PBR SPLIT VPN-FIRST DEFAULT"
add chain=forward src-address=$MIKROTIK_LAN out-interface=$MIKROTIK_OVPN_IF protocol=tcp tcp-flags=syn action=change-mss new-mss=1360 passthrough=yes comment="SVNET MSS clamp OpenVPN"

RSC
}

emit_rsc_fullvpn_mangle() {
  cat <<RSC
/ip firewall mangle
remove [find comment~"SVNET-PBR"]
remove [find comment~"SVNET MSS"]
add chain=prerouting src-address=$MIKROTIK_LAN dst-address-list=SVNET_LOCAL_BYPASS action=accept comment="SVNET-PBR LOCAL BYPASS"
add chain=prerouting src-address=$MIKROTIK_LAN dst-address-type=!local action=mark-routing new-routing-mark=to-vpn passthrough=no comment="SVNET-PBR FULLVPN"
add chain=forward src-address=$MIKROTIK_LAN out-interface=$MIKROTIK_OVPN_IF protocol=tcp tcp-flags=syn action=change-mss new-mss=1360 passthrough=yes comment="SVNET MSS clamp OpenVPN"

RSC
}

emit_rsc_footer() {
  local message="$1"
  cat <<RSC
/ip dns
set allow-remote-requests=yes servers=1.1.1.1,8.8.8.8
cache flush

/ip dhcp-server network
set [find address="$MIKROTIK_LAN"] dns-server=$MIKROTIK_LAN_DNS

/ip firewall connection
remove [find]

:log warning "$message"
RSC
}

emit_routeros_scripts() {
  cat <<RSC

/system script
remove [find name="svnet-health-watch"]
remove [find name="svnet-emergency-direct"]
remove [find name="svnet-ovpn-reconnect"]

add name=svnet-health-watch policy=read,write,test source={
:local ifname "$MIKROTIK_OVPN_IF"
:local gw "$VPN_SERVER_IP"
:if ([:len [/interface find name=\$ifname]] = 0) do={
    :log error "SVNET: ovpn-svnet interface not found"
    :return
}
:local running [/interface get [find name=\$ifname] running]
:if (\$running != true) do={
    :log warning "SVNET: OpenVPN interface is not running, reconnecting"
    /interface ovpn-client disable \$ifname
    :delay 3
    /interface ovpn-client enable \$ifname
    :delay 8
    /ip firewall connection remove [find]
    /ip dns cache flush
    :return
}
:local pingResult [/ping \$gw count=2]
:if (\$pingResult = 0) do={
    :log warning "SVNET: VPN gateway ping failed, reconnecting OpenVPN"
    /interface ovpn-client disable \$ifname
    :delay 3
    /interface ovpn-client enable \$ifname
    :delay 8
    /ip firewall connection remove [find]
    /ip dns cache flush
} else={
    :log info "SVNET: health OK"
}
}

add name=svnet-emergency-direct policy=read,write,test source={
/ip firewall mangle disable [find comment~"SVNET-PBR"]
/ip firewall mangle disable [find comment~"SVNET MSS"]
/ip firewall connection remove [find]
/ip dns cache flush
:log warning "SVNET: emergency DIRECT mode enabled"
}

add name=svnet-ovpn-reconnect policy=read,write,test source={
/interface ovpn-client disable $MIKROTIK_OVPN_IF
:delay 3
/interface ovpn-client enable $MIKROTIK_OVPN_IF
:delay 5
/ip firewall connection remove [find]
/ip dns cache flush
:log warning "SVNET: OpenVPN reconnected"
}

RSC
}

