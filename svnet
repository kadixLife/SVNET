  echo
  echo "Для домашней сети: отключено по умолчанию."
  echo "Включить: sudo svnet --admin-enable-lan-access"
  echo "После включения откройте: $(admin_lan_url)"
  echo
  echo "Developer fallback через SSH tunnel:"
  echo "ssh -L 3000:127.0.0.1:3000 root@$server_ip"
  echo
